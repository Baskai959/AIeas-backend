{
  "openapi": "3.0.3",
  "info": {
    "title": "直播场次记录",
    "version": "v1",
    "description": "新增 live_session（直播场次）维度：每次开播-闭播一组数据，承载本场拍品/出价/成交的统计与回看。包含按直播间、按商家两类列表查询，以及按场次反查拍品/出价/订单的接口。"
  },
  "servers": [
    {
      "url": "http://localhost:8888",
      "description": "Local"
    }
  ],
  "tags": [
    {
      "name": "LiveSession",
      "description": "直播场次"
    }
  ],
  "paths": {
    "/api/v1/live-rooms/{id}/sessions": {
      "get": {
        "tags": ["LiveSession"],
        "summary": "列出直播间的场次",
        "description": "需要登录。商家仅能查看自己直播间的场次；admin 可查询任意直播间。按 id DESC 排序。",
        "operationId": "listLiveSessionsByRoom",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "uint64" },
            "description": "直播间 ID"
          },
          { "$ref": "#/components/parameters/StatusQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": {
            "description": "返回场次列表",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LiveSessionListResponse" }
              }
            }
          },
          "403": { "description": "无直播间操作权限" },
          "404": { "description": "直播间不存在" }
        }
      }
    },
    "/api/v1/merchants/{merchantId}/live-sessions": {
      "get": {
        "tags": ["LiveSession"],
        "summary": "列出商家的所有场次",
        "description": "需要 merchant 或 admin 角色。商家请求时强制以登录账号 ID 作为 merchantId 过滤；admin 可指定任意 merchantId。",
        "operationId": "listLiveSessionsByMerchant",
        "parameters": [
          {
            "name": "merchantId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "商家 ID"
          },
          { "$ref": "#/components/parameters/StatusQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": {
            "description": "返回场次列表",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LiveSessionListResponse" }
              }
            }
          },
          "403": { "description": "无商家场次查询权限" }
        }
      }
    },
    "/api/v1/live-sessions/{sessionId}": {
      "get": {
        "tags": ["LiveSession"],
        "summary": "查看场次详情",
        "description": "返回单个场次的元数据与计数指标。",
        "operationId": "getLiveSession",
        "parameters": [
          { "$ref": "#/components/parameters/SessionIDPath" }
        ],
        "responses": {
          "200": {
            "description": "返回场次详情",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LiveSessionResponse" }
              }
            }
          },
          "404": { "description": "场次不存在" }
        }
      }
    },
    "/api/v1/live-sessions/{sessionId}/lots": {
      "get": {
        "tags": ["LiveSession"],
        "summary": "列出场次内的拍品",
        "description": "通过 auction_lot.live_session_id 反查；含本场内所有拍品。",
        "operationId": "listLiveSessionLots",
        "parameters": [
          { "$ref": "#/components/parameters/SessionIDPath" }
        ],
        "responses": {
          "200": { "description": "返回拍品列表（lots 字段）" },
          "403": { "description": "无场次操作权限" },
          "404": { "description": "场次不存在" }
        }
      }
    },
    "/api/v1/live-sessions/{sessionId}/bids": {
      "get": {
        "tags": ["LiveSession"],
        "summary": "列出场次内的出价",
        "description": "通过本场所属拍品的 bid_record.live_session_id 反查；按价格降序。",
        "operationId": "listLiveSessionBids",
        "parameters": [
          { "$ref": "#/components/parameters/SessionIDPath" },
          { "$ref": "#/components/parameters/LimitQuery" }
        ],
        "responses": {
          "200": { "description": "返回出价记录（bids 字段）" },
          "403": { "description": "无场次操作权限" },
          "404": { "description": "场次不存在" }
        }
      }
    },
    "/api/v1/live-sessions/{sessionId}/orders": {
      "get": {
        "tags": ["LiveSession"],
        "summary": "列出场次产生的订单",
        "description": "通过 order_deal.live_session_id 反查；按 ID 降序。",
        "operationId": "listLiveSessionOrders",
        "parameters": [
          { "$ref": "#/components/parameters/SessionIDPath" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": { "description": "返回订单列表（orders 字段）" },
          "403": { "description": "无场次操作权限" },
          "404": { "description": "场次不存在" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "SessionIDPath": {
        "name": "sessionId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer", "format": "uint64" },
        "description": "直播场次 ID"
      },
      "StatusQuery": {
        "name": "status",
        "in": "query",
        "required": false,
        "schema": { "type": "string", "enum": ["LIVE", "ENDED"] },
        "description": "按场次状态过滤"
      },
      "LimitQuery": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "default": 20, "minimum": 1, "maximum": 100 }
      },
      "OffsetQuery": {
        "name": "offset",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "default": 0, "minimum": 0 }
      }
    },
    "schemas": {
      "LiveSession": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "uint64" },
          "liveRoomId": { "type": "integer", "format": "uint64" },
          "merchantId": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string", "enum": ["LIVE", "ENDED"] },
          "openedAt": { "type": "string", "format": "date-time" },
          "closedAt": { "type": "string", "format": "date-time", "nullable": true },
          "lotsTotal": { "type": "integer" },
          "lotsSold": { "type": "integer" },
          "lotsUnsold": { "type": "integer" },
          "bidCount": { "type": "integer" },
          "gmvCent": { "type": "integer", "format": "int64" },
          "viewerPeak": { "type": "integer" },
          "viewerTotal": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "LiveSessionResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "example": 0 },
          "message": { "type": "string", "example": "success" },
          "data": { "$ref": "#/components/schemas/LiveSession" },
          "trace_id": { "type": "string" }
        }
      },
      "LiveSessionListResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "example": 0 },
          "message": { "type": "string", "example": "success" },
          "data": {
            "type": "object",
            "properties": {
              "sessions": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/LiveSession" }
              }
            }
          },
          "trace_id": { "type": "string" }
        }
      }
    }
  }
}

{
  "openapi": "3.0.3",
  "info": {
    "title": "AI电商拍卖系统 - 用户端发现与参与接口",
    "version": "2026-06-04",
    "description": "用户端发现页、拍品详情、我的竞拍、分类、商家搜索与订单 auctionId 过滤接口。REST 响应统一包裹为 {code,message,data,trace_id}；金额单位为分；时间字段为 RFC3339。"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8080",
      "description": "本地默认服务地址"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Marketplace",
      "description": "用户端发现、搜索、拍品详情、分类与商家主页"
    },
    {
      "name": "Participation",
      "description": "买家竞拍参与记录聚合"
    },
    {
      "name": "Order",
      "description": "用户订单查询"
    }
  ],
  "paths": {
    "/api/v1/search/lots": {
      "get": {
        "tags": [
          "Marketplace"
        ],
        "summary": "搜索用户端可见拍品",
        "description": "用于发现页、分类页、商品搜索、商家商品列表。买家可访问，仅返回用户端可见状态：READY、WARMING_UP、RUNNING、EXTENDED、HAMMER_PENDING、CLOSED_WON、CLOSED_FAILED、SETTLED。",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "关键词，匹配拍品标题、描述、类目、品牌等展示字段。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "排序方式；不传默认按 auctionId 倒序。",
            "schema": {
              "type": "string",
              "enum": [
                "priceAsc",
                "priceDesc",
                "endingSoon",
                "startTimeAsc",
                "startTimeDesc",
                "latest",
                "newest"
              ]
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "拍品状态筛选；若传入非用户端可见状态，返回空列表。",
            "schema": {
              "$ref": "#/components/schemas/AuctionStatus"
            }
          },
          {
            "name": "categoryId",
            "in": "query",
            "description": "类目 ID，例如 jewelry、collectible、luxury、digital、camera。后端会同时匹配类目 ID 与中文类目名。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "merchantId",
            "in": "query",
            "description": "商家用户 ID，用于商家主页拍品列表。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "分页大小，默认 20。",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "分页偏移，默认 0。",
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "搜索结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LotSearchResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/api/v1/lots/{id}": {
      "get": {
        "tags": [
          "Marketplace"
        ],
        "summary": "获取用户端拍品详情",
        "description": "用于商品详情页。买家可访问，只返回用户端可见状态的拍品；不可见或不存在时返回 404。",
        "parameters": [
          {
            "$ref": "#/components/parameters/LotId"
          }
        ],
        "responses": {
          "200": {
            "description": "拍品详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LotDetailResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/api/v1/auction-participations/mine": {
      "get": {
        "tags": [
          "Participation"
        ],
        "summary": "我的竞拍参与记录",
        "description": "用于“我的竞拍 / 我的订单快捷入口”。仅买家角色可访问，聚合保证金记录、拍品、直播场次与订单。",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "分页大小，默认 20。",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "分页偏移，默认 0。",
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "我的竞拍参与记录",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParticipationListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "403": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/api/v1/categories": {
      "get": {
        "tags": [
          "Marketplace"
        ],
        "summary": "获取用户端类目",
        "description": "用于发现页和搜索页的分类筛选。",
        "responses": {
          "200": {
            "description": "类目列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoryListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/api/v1/search/merchants": {
      "get": {
        "tags": [
          "Marketplace"
        ],
        "summary": "搜索商家",
        "description": "用于用户端商家搜索。只返回 active merchant。",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "关键词，匹配商家 ID、账号或昵称。",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "分页大小，默认 20。",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "分页偏移，默认 0。",
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "商家搜索结果",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MerchantSearchResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/api/v1/merchants/{id}": {
      "get": {
        "tags": [
          "Marketplace"
        ],
        "summary": "获取商家主页信息",
        "description": "返回 active merchant 信息；优先带当前直播场次，否则带最近一场直播场次 ID。",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "商家用户 ID。",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "商家主页信息",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MerchantDetailResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/api/v1/orders/mine": {
      "get": {
        "tags": [
          "Order"
        ],
        "summary": "我的订单",
        "description": "现有接口补充 auctionId 查询参数，用于前端按拍品直接过滤订单。",
        "parameters": [
          {
            "name": "auctionId",
            "in": "query",
            "description": "按拍品 ID 过滤我的订单，例如 /api/v1/orders/mine?auctionId=123。",
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 1
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "订单状态筛选。",
            "schema": {
              "$ref": "#/components/schemas/OrderStatus"
            }
          },
          {
            "name": "payStatus",
            "in": "query",
            "description": "支付状态筛选。",
            "schema": {
              "$ref": "#/components/schemas/PayStatus"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "分页大小，默认 20。",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "分页偏移，默认 0。",
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "我的订单列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderListResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "LotId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "拍品 ID。",
        "schema": {
          "type": "integer",
          "format": "int64",
          "minimum": 1
        }
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "统一错误响应",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "description": "业务错误码。"
          },
          "message": {
            "type": "string",
            "description": "错误说明。"
          },
          "data": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true,
            "description": "错误附加信息。"
          },
          "trace_id": {
            "type": "string",
            "description": "请求追踪 ID。"
          }
        }
      },
      "LotSearchResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "required": [
              "lots",
              "total"
            ],
            "properties": {
              "lots": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AuctionLot"
                }
              },
              "total": {
                "type": "integer",
                "format": "int64",
                "description": "满足筛选条件的总数。"
              }
            }
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "LotDetailResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/AuctionLot"
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "ParticipationListResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "required": [
              "records"
            ],
            "properties": {
              "records": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AuctionParticipationRecord"
                }
              }
            }
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "CategoryListResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "required": [
              "categories"
            ],
            "properties": {
              "categories": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Category"
                },
                "example": [
                  {
                    "id": "jewelry",
                    "name": "珠宝玉石",
                    "iconName": "gem"
                  }
                ]
              }
            }
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "MerchantSearchResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "required": [
              "merchants"
            ],
            "properties": {
              "merchants": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/MerchantView"
                }
              }
            }
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "MerchantDetailResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/MerchantView"
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "OrderListResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "required": [
              "orders"
            ],
            "properties": {
              "orders": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/OrderDeal"
                }
              }
            }
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "AuctionLot": {
        "type": "object",
        "description": "拍品。用户端接口会额外补充 categoryId、imageUrl、participantCount，并在有实时状态时补 currentPrice、leaderBidderId、bidCount。",
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "int64",
            "description": "拍品 ID。"
          },
          "sellerId": {
            "type": "string",
            "description": "商家用户 ID。"
          },
          "liveSessionId": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "所属直播场次 ID。"
          },
          "title": {
            "type": "string",
            "description": "拍品标题。"
          },
          "description": {
            "type": "string",
            "description": "拍品描述。"
          },
          "category": {
            "type": "string",
            "description": "类目名称或原始类目值。"
          },
          "categoryId": {
            "type": "string",
            "description": "用户端类目 ID；后端从 category 映射补充。"
          },
          "brand": {
            "type": "string",
            "description": "品牌。"
          },
          "condition": {
            "type": "string",
            "description": "成色/品相。"
          },
          "imageUrls": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "拍品图片列表。"
          },
          "imageUrl": {
            "type": "string",
            "description": "用户端主图，优先取 coverUrl，其次取 imageUrls 第一张。"
          },
          "coverUrl": {
            "type": "string",
            "description": "拍品封面图。"
          },
          "auctionType": {
            "type": "string",
            "enum": [
              "ENGLISH"
            ],
            "description": "拍卖类型。"
          },
          "startPrice": {
            "type": "integer",
            "format": "int64",
            "description": "起拍价，单位分。"
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64",
            "description": "保留价，单位分。"
          },
          "capPrice": {
            "type": "integer",
            "format": "int64",
            "description": "封顶价，单位分；0 表示不设置封顶价。"
          },
          "incrementRule": {
            "$ref": "#/components/schemas/IncrementRule"
          },
          "antiSnipingSec": {
            "type": "integer",
            "description": "反狙击触发窗口，单位秒。"
          },
          "antiExtendSec": {
            "type": "integer",
            "description": "反狙击单次延时时长，单位秒。"
          },
          "antiExtendMode": {
            "type": "string",
            "enum": [
              "ADD",
              "RESET"
            ],
            "description": "反狙击延时模式。"
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64",
            "description": "报名保证金金额，单位分。"
          },
          "status": {
            "$ref": "#/components/schemas/AuctionStatus"
          },
          "ruleSnapshot": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true,
            "description": "拍品规则快照，用于审核和追溯。"
          },
          "startTime": {
            "type": "string",
            "format": "date-time",
            "description": "拍卖开始时间。"
          },
          "endTime": {
            "type": "string",
            "format": "date-time",
            "description": "拍卖结束时间。"
          },
          "durationSec": {
            "type": "integer",
            "description": "持续秒数。"
          },
          "winnerId": {
            "type": "string",
            "nullable": true,
            "description": "成交买家 ID。"
          },
          "dealPrice": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "成交价，单位分。"
          },
          "closedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "关闭时间。"
          },
          "closedBy": {
            "type": "string",
            "description": "关闭操作者。"
          },
          "currentPrice": {
            "type": "integer",
            "format": "int64",
            "description": "当前价，单位分。"
          },
          "leaderBidderId": {
            "type": "string",
            "description": "当前领先买家 ID。"
          },
          "bidCount": {
            "type": "integer",
            "description": "出价次数。"
          },
          "participantCount": {
            "type": "integer",
            "description": "报名/缴纳保证金的参与人数。"
          },
          "version": {
            "type": "integer",
            "format": "int64",
            "description": "行版本号。"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "IncrementRule": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FixedIncrementRule"
          },
          {
            "$ref": "#/components/schemas/LadderIncrementRule"
          }
        ],
        "description": "加价规则。固定加价为 type=fixed；阶梯加价为 type=ladder。"
      },
      "FixedIncrementRule": {
        "type": "object",
        "required": [
          "type",
          "amount",
          "maxBidSteps"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "fixed"
            ]
          },
          "amount": {
            "type": "integer",
            "format": "int64",
            "description": "每步加价金额，单位分。"
          },
          "maxBidSteps": {
            "type": "integer",
            "description": "单次最高可加价步数。"
          }
        }
      },
      "LadderIncrementRule": {
        "type": "object",
        "required": [
          "type",
          "steps",
          "maxBidSteps"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ladder"
            ]
          },
          "maxBidSteps": {
            "type": "integer",
            "description": "单次最高可加价步数。"
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IncrementStep"
            },
            "description": "阶梯配置，第一段 min 必须为 0，最后一段省略 max。"
          }
        }
      },
      "IncrementStep": {
        "type": "object",
        "required": [
          "min",
          "amount"
        ],
        "properties": {
          "min": {
            "type": "integer",
            "format": "int64",
            "description": "该阶梯下界，单位分。"
          },
          "max": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "该阶梯上界，不包含；最后一段为空。"
          },
          "amount": {
            "type": "integer",
            "format": "int64",
            "description": "该阶梯每步加价金额，单位分。"
          }
        }
      },
      "LiveSessionView": {
        "type": "object",
        "description": "用户端直播场次视图，在 LiveSession 基础上补充展示字段。",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "直播场次 ID。"
          },
          "merchantId": {
            "type": "string",
            "description": "商家用户 ID。"
          },
          "merchantName": {
            "type": "string",
            "description": "商家展示名。"
          },
          "title": {
            "type": "string",
            "description": "场次标题。"
          },
          "description": {
            "type": "string",
            "description": "场次描述。"
          },
          "coverUrl": {
            "type": "string",
            "description": "场次封面。"
          },
          "status": {
            "$ref": "#/components/schemas/LiveSessionStatus"
          },
          "activeAuctionId": {
            "type": "integer",
            "format": "int64",
            "description": "当前讲解/拍卖拍品 ID。"
          },
          "videoSource": {
            "type": "string",
            "description": "视频源类型；当前实现预留为空字符串。"
          },
          "videoUrl": {
            "type": "string",
            "description": "视频播放地址；当前实现预留为空字符串。"
          },
          "digitalHuman": {
            "type": "object",
            "additionalProperties": true,
            "description": "数字人配置；当前实现返回空对象。"
          },
          "onlineCount": {
            "type": "integer",
            "description": "当前在线人数；基于 activeAuctionId 的 WebSocket Hub 在线数。"
          },
          "openedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "closedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "scheduledStartTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "plannedDurationSec": {
            "type": "integer"
          },
          "lotsTotal": {
            "type": "integer"
          },
          "lotsSold": {
            "type": "integer"
          },
          "lotsUnsold": {
            "type": "integer"
          },
          "bidCount": {
            "type": "integer"
          },
          "gmvCent": {
            "type": "integer",
            "format": "int64"
          },
          "viewerPeak": {
            "type": "integer"
          },
          "viewerTotal": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MerchantView": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "商家用户 ID。"
          },
          "name": {
            "type": "string",
            "description": "商家展示名。"
          },
          "avatarUrl": {
            "type": "string",
            "description": "商家头像。"
          },
          "followerCount": {
            "type": "integer",
            "description": "粉丝数；当前实现返回 0。"
          },
          "liveRoomId": {
            "type": "string",
            "description": "兼容字段，当前等于 liveSessionId 的字符串形式。"
          },
          "liveSessionId": {
            "type": "integer",
            "format": "int64",
            "description": "当前或最近直播场次 ID。"
          },
          "currentLiveSession": {
            "$ref": "#/components/schemas/LiveSessionView"
          }
        }
      },
      "AuctionParticipationRecord": {
        "type": "object",
        "required": [
          "id",
          "userId",
          "depositAmount",
          "depositStatus",
          "enrolledAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "参与记录 ID，当前为保证金流水 ID 的字符串形式。"
          },
          "userId": {
            "type": "string",
            "description": "买家用户 ID。"
          },
          "lot": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/AuctionLot"
              }
            ]
          },
          "room": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/LiveSessionView"
              }
            ]
          },
          "order": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/OrderDeal"
              }
            ]
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64",
            "description": "保证金金额，单位分。"
          },
          "depositStatus": {
            "$ref": "#/components/schemas/DepositStatus"
          },
          "enrolledAt": {
            "type": "string",
            "format": "date-time",
            "description": "报名/保证金记录创建时间。"
          }
        }
      },
      "OrderDeal": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "订单 ID。"
          },
          "auctionId": {
            "type": "integer",
            "format": "int64",
            "description": "拍品 ID。"
          },
          "liveSessionId": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "description": "直播场次 ID。"
          },
          "lotSnapshot": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true,
            "description": "成交时拍品快照。"
          },
          "winnerId": {
            "type": "string",
            "description": "买家用户 ID。"
          },
          "winnerNickname": {
            "type": "string",
            "description": "买家昵称。"
          },
          "sellerId": {
            "type": "string",
            "description": "商家用户 ID。"
          },
          "dealPrice": {
            "type": "integer",
            "format": "int64",
            "description": "成交价，单位分。"
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64",
            "description": "抵扣/冻结保证金，单位分。"
          },
          "status": {
            "$ref": "#/components/schemas/OrderStatus"
          },
          "payStatus": {
            "$ref": "#/components/schemas/PayStatus"
          },
          "fulfillmentStatus": {
            "$ref": "#/components/schemas/FulfillmentStatus"
          },
          "payDeadline": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "支付截止时间。"
          },
          "paidAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "支付时间。"
          },
          "shippedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "发货时间。"
          },
          "receivedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "收货时间。"
          },
          "closedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "关闭时间。"
          },
          "version": {
            "type": "integer",
            "format": "int64"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Category": {
        "type": "object",
        "required": [
          "id",
          "name",
          "iconName"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "类目 ID。"
          },
          "name": {
            "type": "string",
            "description": "类目名称。"
          },
          "iconName": {
            "type": "string",
            "description": "前端图标名。"
          }
        }
      },
      "AuctionStatus": {
        "type": "string",
        "enum": [
          "DRAFT",
          "PENDING_AUDIT",
          "AUDIT_REJECTED",
          "READY",
          "WARMING_UP",
          "RUNNING",
          "EXTENDED",
          "HAMMER_PENDING",
          "CLOSED_WON",
          "CLOSED_FAILED",
          "SETTLED"
        ]
      },
      "LiveSessionStatus": {
        "type": "string",
        "enum": [
          "DRAFT",
          "SCHEDULED",
          "LIVE",
          "ENDED",
          "CANCELLED"
        ]
      },
      "DepositStatus": {
        "type": "string",
        "enum": [
          "PENDING",
          "READY",
          "CAPTURED",
          "RELEASED",
          "FAILED"
        ]
      },
      "OrderStatus": {
        "type": "string",
        "enum": [
          "CREATED",
          "PAID",
          "TIMEOUT",
          "CANCELLED"
        ]

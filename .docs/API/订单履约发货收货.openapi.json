{
  "openapi": "3.0.3",
  "info": {
    "title": "订单履约发货收货接口",
    "version": "1.0.0",
    "description": "订单支付后的履约动作：商家发货、买家确认收货。"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000"
    }
  ],
  "paths": {
    "/api/v1/orders/{id}/ship": {
      "post": {
        "tags": ["Order"],
        "summary": "商家发货",
        "description": "需要 merchant 或 admin 角色，并要求 Idempotency-Key。仅已支付且 fulfillmentStatus=UNSHIPPED 的订单可发货；成功后 fulfillmentStatus=SHIPPED，返回订单详情。",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" },
          { "$ref": "#/components/parameters/IdempotencyKey" }
        ],
        "responses": {
          "200": {
            "description": "发货成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OrderResponse" },
                "example": {
                  "code": 0,
                  "message": "ok",
                  "data": {
                    "id": 3001,
                    "auctionId": 2001,
                    "winnerId": "u_1001",
                    "sellerId": "u_2001",
                    "dealPrice": 120000,
                    "depositAmount": 10000,
                    "status": "PAID",
                    "payStatus": "PAID",
                    "fulfillmentStatus": "SHIPPED",
                    "paidAt": "2026-06-07T12:00:00Z",
                    "shippedAt": "2026-06-07T12:30:00Z",
                    "createdAt": "2026-06-07T11:50:00Z",
                    "updatedAt": "2026-06-07T12:30:00Z"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/v1/orders/{id}/receive": {
      "post": {
        "tags": ["Order"],
        "summary": "买家确认收货",
        "description": "需要 buyer 或 admin 角色，并要求 Idempotency-Key。仅已支付且 fulfillmentStatus=SHIPPED 的订单可确认收货；成功后 fulfillmentStatus=RECEIVED，返回订单详情。",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" },
          { "$ref": "#/components/parameters/IdempotencyKey" }
        ],
        "responses": {
          "200": {
            "description": "确认收货成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OrderResponse" },
                "example": {
                  "code": 0,
                  "message": "ok",
                  "data": {
                    "id": 3001,
                    "auctionId": 2001,
                    "winnerId": "u_1001",
                    "sellerId": "u_2001",
                    "dealPrice": 120000,
                    "depositAmount": 10000,
                    "status": "PAID",
                    "payStatus": "PAID",
                    "fulfillmentStatus": "RECEIVED",
                    "paidAt": "2026-06-07T12:00:00Z",
                    "shippedAt": "2026-06-07T12:30:00Z",
                    "receivedAt": "2026-06-07T13:00:00Z",
                    "createdAt": "2026-06-07T11:50:00Z",
                    "updatedAt": "2026-06-07T13:00:00Z"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "OrderId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer", "format": "uint64" },
        "description": "订单 ID"
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "schema": { "type": "string", "minLength": 1 },
        "description": "写操作幂等键"
      }
    },
    "schemas": {
      "BaseResponse": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "integer" },
          "message": { "type": "string" },
          "trace_id": { "type": "string" }
        }
      },
      "OrderStatus": {
        "type": "string",
        "enum": ["CREATED", "PAID", "TIMEOUT", "CANCELLED"]
      },
      "PayStatus": {
        "type": "string",
        "enum": ["UNPAID", "PAID", "REFUNDED"]
      },
      "FulfillmentStatus": {
        "type": "string",
        "enum": ["UNSHIPPED", "SHIPPED", "RECEIVED"]
      },
      "OrderDeal": {
        "type": "object",
        "required": ["id", "auctionId", "winnerId", "sellerId", "dealPrice", "depositAmount", "status", "payStatus", "fulfillmentStatus", "createdAt", "updatedAt"],
        "properties": {
          "id": { "type": "integer", "format": "uint64" },
          "auctionId": { "type": "integer", "format": "uint64" },
          "liveSessionId": { "type": "integer", "format": "uint64", "nullable": true },
          "lotSnapshot": { "type": "object", "nullable": true, "additionalProperties": true },
          "winnerId": { "type": "string" },
          "winnerNickname": { "type": "string" },
          "sellerId": { "type": "string" },
          "dealPrice": { "type": "integer", "format": "int64" },
          "depositAmount": { "type": "integer", "format": "int64" },
          "status": { "$ref": "#/components/schemas/OrderStatus" },
          "payStatus": { "$ref": "#/components/schemas/PayStatus" },
          "fulfillmentStatus": { "$ref": "#/components/schemas/FulfillmentStatus" },
          "payDeadline": { "type": "string", "format": "date-time", "nullable": true },
          "paidAt": { "type": "string", "format": "date-time", "nullable": true },
          "shippedAt": { "type": "string", "format": "date-time", "nullable": true },
          "receivedAt": { "type": "string", "format": "date-time", "nullable": true },
          "closedAt": { "type": "string", "format": "date-time", "nullable": true },
          "version": { "type": "integer", "format": "int64" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "OrderResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/BaseResponse" },
          {
            "type": "object",
            "properties": {
              "data": { "$ref": "#/components/schemas/OrderDeal" }
            }
          }
        ]
      },
      "ErrorResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/BaseResponse" },
          {
            "type": "object",
            "properties": {
              "data": { "nullable": true }
            }
          }
        ]
      }
    },
    "responses": {
      "BadRequest": {
        "description": "请求参数错误",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "Unauthorized": {
        "description": "未登录或令牌无效",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "Forbidden": {
        "description": "无权限操作该订单",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      },
      "Conflict": {
        "description": "当前订单状态不允许该操作",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
      }
    }
  }
}

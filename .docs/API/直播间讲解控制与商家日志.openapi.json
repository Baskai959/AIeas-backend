{
  "openapi": "3.0.3",
  "info": {
    "title": "直播间讲解控制与商家日志",
    "version": "v1",
    "description": "补充直播间开拍时长、结束当前拍品讲解但保持直播中，以及商家端操作日志查询接口。"
  },
  "servers": [
    {
      "url": "http://localhost:8888",
      "description": "Local"
    }
  ],
  "tags": [
    {
      "name": "LiveRoom",
      "description": "直播间与讲解控制"
    },
    {
      "name": "Audit",
      "description": "操作日志"
    }
  ],
  "paths": {
    "/api/v1/live-rooms/{id}/activate": {
      "post": {
        "tags": [
          "LiveRoom"
        ],
        "summary": "开始讲解拍品",
        "description": "需要 merchant 或 admin 角色。durationSec 大于 0 时，后端以当前服务器时间作为 startTime，并按 durationSec 计算 endTime；durationMinutes 兼容前端入参但不作为计算依据。",
        "operationId": "activateLiveRoomAuctionWithDuration",
        "parameters": [
          {
            "$ref": "#/components/parameters/LiveRoomIDPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LiveRoomActivateRequest"
              },
              "example": {
                "auctionId": 51992240194048,
                "durationMinutes": 10,
                "durationSec": 600
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "开始讲解成功，返回拍品；拍品 startTime/endTime 已按 durationSec 更新"
          },
          "400": {
            "description": "参数不合法"
          },
          "409": {
            "description": "直播间已有拍品在拍或拍品状态不允许开拍"
          }
        }
      }
    },
    "/api/v1/live-rooms/{id}/deactivate": {
      "post": {
        "tags": [
          "LiveRoom"
        ],
        "summary": "结束当前拍品讲解",
        "description": "需要 merchant 或 admin 角色。仅清空 activeAuctionId 并释放直播间拍品锁；直播间保持 LIVE。下播请调用直播间编辑接口将 status 改为 OFFLINE。",
        "operationId": "deactivateLiveRoomActiveAuction",
        "parameters": [
          {
            "$ref": "#/components/parameters/LiveRoomIDPath"
          }
        ],
        "responses": {
          "200": {
            "description": "结束当前拍品讲解成功，返回直播间"
          },
          "403": {
            "description": "无直播间操作权限"
          },
          "404": {
            "description": "直播间不存在"
          }
        }
      }
    },
    "/api/v1/audit-logs": {
      "get": {
        "tags": [
          "Audit"
        ],
        "summary": "查询当前账号操作日志",
        "description": "需要 merchant 或 admin 角色。只返回当前登录账号自己的操作日志，商家无法通过该接口查询其他账号日志。",
        "operationId": "listOwnAuditLogs",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          {
            "name": "action",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startTime",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "endTime",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditLogPageResponse"
                }
              }
            }
          },
          "403": {
            "description": "无访问权限"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "LiveRoomIDPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "uint64",
          "minimum": 1
        },
        "description": "直播间 ID"
      }
    },
    "schemas": {
      "LiveRoomActivateRequest": {
        "type": "object",
        "required": [
          "auctionId"
        ],
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1
          },
          "durationSec": {
            "type": "integer",
            "minimum": 1,
            "description": "讲解时长，单位秒；后端以该字段为准计算 startTime/endTime"
          },
          "durationMinutes": {
            "type": "integer",
            "minimum": 1,
            "description": "前端展示字段，后端允许传入但不作为计算依据"
          }
        }
      },
      "AuditLogPageResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AuditLog"
                }
              },
              "total": {
                "type": "integer"
              },
              "page": {
                "type": "integer"
              },
              "page_size": {
                "type": "integer"
              }
            }
          }
        }
      },
      "AuditLog": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64"
          },
          "operatorId": {
            "type": "string"
          },
          "operatorRole": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "targetType": {
            "type": "string"
          },
          "targetId": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          },
          "ip": {
            "type": "string"
          },
          "userAgent": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}

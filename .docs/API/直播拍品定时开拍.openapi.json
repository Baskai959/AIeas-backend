{
  "openapi": "3.0.3",
  "info": {
    "title": "直播拍品定时开拍",
    "version": "1.0.0",
    "description": "更新直播场次拍品开拍接口：商家可以选择立即开拍，也可以传 startTime 和 durationSec 预约未来开拍。预约时后端先把拍品置为 WARMING_UP，到点由后台 worker 走原开拍链路写入 activeAuctionId、初始化 Redis 实时状态并广播 auction.started。"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/api/v1/live-sessions/{id}/activate": {
      "post": {
        "tags": [
          "直播场次"
        ],
        "summary": "开始或预约拍品拍卖",
        "description": "需要 merchant 或 admin 角色，并要求 Idempotency-Key。startTime 不传或不晚于服务端当前时间时立即开拍；startTime 晚于服务端当前时间时预约开拍，此时 durationSec 必须大于 0。预约成功后拍品状态为 WARMING_UP，直播场次 activeAuctionId 暂不变；到点后后台 worker 自动启动拍卖。",
        "operationId": "activateOrScheduleLiveSessionAuction",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64"
            },
            "description": "直播场次 ID"
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "幂等键，同一次开拍或预约操作保持一致。"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ActivateLiveSessionAuctionRequest"
              },
              "examples": {
                "immediate": {
                  "summary": "立即开拍",
                  "value": {
                    "auctionId": 56460805538304,
                    "durationSec": 600
                  }
                },
                "scheduled": {
                  "summary": "预约开拍",
                  "value": {
                    "auctionId": 56460805538304,
                    "startTime": "2026-06-06T13:30:00.000Z",
                    "durationSec": 600
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "立即开拍或预约成功，返回拍品。预约成功时 status 为 WARMING_UP；立即开拍成功时 status 通常为 RUNNING。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuctionLotResponse"
                }
              }
            }
          },
          "400": {
            "description": "参数不合法，例如 auctionId 为空，或预约未来开拍但 durationSec 未传/小于等于 0。"
          },
          "403": {
            "description": "无权限操作该直播场次或拍品。"
          },
          "404": {
            "description": "直播场次或拍品不存在。"
          },
          "409": {
            "description": "直播场次未开播、已有 active 拍品、拍品未挂载到该场次、拍品状态不允许开拍，或该场次已有其他预约中的拍品。"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "ActivateLiveSessionAuctionRequest": {
        "type": "object",
        "required": [
          "auctionId"
        ],
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "uint64",
            "description": "拍品 ID。"
          },
          "startTime": {
            "type": "string",
            "format": "date-time",
            "description": "预约开拍时间，RFC3339。未来时间表示定时开拍；不传表示立即开拍。"
          },
          "durationSec": {
            "type": "integer",
            "minimum": 0,
            "description": "本次拍卖时长，单位秒。预约未来开拍时必须大于 0；立即开拍时建议传入，后端会按服务端当前时间计算 endTime。"
          }
        }
      },
      "AuctionLotResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/AuctionLot"
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "AuctionLot": {
        "type": "object",
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "uint64"
          },
          "sellerId": {
            "type": "string"
          },
          "liveSessionId": {
            "type": "integer",
            "format": "uint64"
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PENDING_AUDIT",
              "AUDIT_REJECTED",
              "READY",
              "WARMING_UP",
              "RUNNING",
              "EXTENDED",
              "HAMMER_PENDING",
              "CLOSED_WON",
              "CLOSED_FAILED",
              "SETTLED"
            ]
          },
          "startPrice": {
            "type": "integer",
            "format": "int64"
          },
          "currentPrice": {
            "type": "integer",
            "format": "int64"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "durationSec": {
            "type": "integer"
          }
        }
      }
    }
  }
}

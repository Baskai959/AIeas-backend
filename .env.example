# Copy this file to .env for local development and replace values with real secrets.
# Do not commit .env.

SERVER_ADDR=:8888

MYSQL_DSN=auction:auction@tcp(127.0.0.1:3306)/auction?charset=utf8mb4&parseTime=true&loc=Local
MYSQL_MAX_OPEN_CONNS=100
MYSQL_MAX_IDLE_CONNS=20
MYSQL_CONN_MAX_LIFETIME=1h

REDIS_ADDR=127.0.0.1:6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=100

JWT_ISSUER=realtime-auction-master
JWT_SECRET=replace-with-a-strong-local-secret
JWT_ACCESS_TOKEN_TTL=12h

IDGEN_WORKER_ID=1

IDEMPOTENCY_TTL=24h

AUCTION_MIN_INCREMENT_CENT=100
AUCTION_ANTI_SNIPE_MS=30000
AUCTION_EXTEND_MS=30000
AUCTION_MAX_EXTEND_COUNT=20
AUCTION_FREQ_LIMIT_COUNT=10
AUCTION_FREQ_WINDOW_MS=1000

WEBSOCKET_READ_LIMIT_BYTES=65536
WEBSOCKET_SEND_BUFFER_SIZE=256
WEBSOCKET_PING_INTERVAL=20s
WEBSOCKET_PONG_TIMEOUT=60s

OBJECT_STORAGE_ENABLED=false
OBJECT_STORAGE_ENDPOINT=https://tos-cn-boe.volces.com
OBJECT_STORAGE_REGION=cn-guilin-boe
OBJECT_STORAGE_BUCKET=aieas
OBJECT_STORAGE_BUCKET_URL=https://aieas.tos-cn-boe.volces.com
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_OBJECT_PREFIX=

AGENT_PRODUCT_DESCRIPTION_URL=http://127.0.0.1:8000/api/v1/product-description
AGENT_PRODUCT_AUDIT_URL=http://127.0.0.1:8000/api/v1/product-audit
AGENT_TIMEOUT=30s

OBSERVABILITY_LOG_LEVEL=info
OBSERVABILITY_METRICS_PATH=/metrics
# Log format: text (dev/colorful) or json (prod, one line per record)
OBSERVABILITY_FORMAT=text
# GORM slow SQL threshold in milliseconds; set <=0 to disable
OBSERVABILITY_SLOW_SQL_THRESHOLD_MS=200

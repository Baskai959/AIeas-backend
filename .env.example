# Copy this file to .env for local development and replace values with real secrets.
# Do not commit .env.

SERVER_ADDR=:8888

MYSQL_DSN=auction:auction@tcp(127.0.0.1:3306)/auction?charset=utf8mb4&parseTime=true&loc=Local
MYSQL_MAX_OPEN_CONNS=100
MYSQL_MAX_IDLE_CONNS=20
MYSQL_CONN_MAX_LIFETIME=1h

# Redis RT 分片：按 REDIS_RT_SHARD_<N>_* 命名，N 从 0 起；至少 1 个 shard。
# 应用层按聚合根（auctionID/sessionID/roomID）的 fnv32 哈希路由到具体 shard，
# 全局 key 固定到 shard 0。历史的 REDIS_RT_PRIMARY_* 仍兼容（映射到 SHARD_0_*）。
REDIS_RT_SHARD_0_ADDR=127.0.0.1:6381
REDIS_RT_SHARD_0_USERNAME=default
REDIS_RT_SHARD_0_PASSWORD=
REDIS_RT_SHARD_0_DB=0
REDIS_RT_SHARD_0_POOL_SIZE=100

REDIS_RT_SHARD_1_ADDR=127.0.0.1:6382
REDIS_RT_SHARD_1_USERNAME=default
REDIS_RT_SHARD_1_PASSWORD=
REDIS_RT_SHARD_1_DB=0
REDIS_RT_SHARD_1_POOL_SIZE=100

REDIS_CACHE_ADDR=127.0.0.1:6380
REDIS_CACHE_USERNAME=default
REDIS_CACHE_PASSWORD=
REDIS_CACHE_DB=0
REDIS_CACHE_POOL_SIZE=100

JWT_ISSUER=realtime-auction-master
JWT_SECRET=replace-with-a-strong-local-secret
JWT_ACCESS_TOKEN_TTL=12h

IDGEN_WORKER_ID=1

IDEMPOTENCY_TTL=24h

AUCTION_MIN_INCREMENT_CENT=100
AUCTION_ANTI_SNIPE_MS=30000
AUCTION_EXTEND_MS=30000
AUCTION_MAX_EXTEND_COUNT=20
AUCTION_FREQ_LIMIT_COUNT=10
AUCTION_FREQ_WINDOW_MS=1000
AUCTION_BID_IDEMPOTENCY_TTL=30s

# 压测/应急总开关。false 时关闭 HTTP 限流、出价频控、黑名单拦截和自动拉黑；
# 出价仍会执行正常业务规则校验，不合法出价照常拒绝。
RISK_CONTROL_ENABLED=true

WEBSOCKET_READ_LIMIT_BYTES=65536
WEBSOCKET_SEND_BUFFER_SIZE=256
WEBSOCKET_PING_INTERVAL=20s
WEBSOCKET_PONG_TIMEOUT=60s

OBJECT_STORAGE_ENABLED=false
OBJECT_STORAGE_ENDPOINT=https://tos-cn-boe.volces.com
OBJECT_STORAGE_REGION=cn-guilin-boe
OBJECT_STORAGE_BUCKET=aieas
OBJECT_STORAGE_BUCKET_URL=https://aieas.tos-cn-boe.volces.com
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_OBJECT_PREFIX=

AGENT_PRODUCT_DESCRIPTION_URL=http://127.0.0.1:8000/api/v1/product-description
# false 时不调用 AI 审核，拍品提交审核后默认直接通过；true 时走 AI 审核回调流程。
AGENT_PRODUCT_AUDIT_ENABLED=true
AGENT_PRODUCT_AUDIT_URL=http://127.0.0.1:8000/api/v1/product-audit
AGENT_PRODUCT_AUDIT_CALLBACK_URL=http://127.0.0.1:8888/api/v1/auctions/audit/callback
AGENT_LIVE_ANALYSIS_URL=http://127.0.0.1:8000/api/v1/live-analysis/async
AGENT_LIVE_ANALYSIS_CALLBACK_URL=http://127.0.0.1:8888/api/v1/live-analysis/callback
AGENT_LIVE_ANALYSIS_CALLBACK_API_KEY=replace-with-a-strong-live-analysis-callback-key
AGENT_LIVE_AUCTION_HOOK_URL=http://127.0.0.1:8000/api/v1/live-auction-hook
AGENT_TIMEOUT=30s

DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACK_TOKEN=
DOUBAO_TTS_VOICE=zh_female_vv_jupiter_bigtts

KAFKA_ENABLED=false
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CLIENT_ID=aieas-backend
KAFKA_BID_EVENTS_TOPIC=aieas.bid.events
KAFKA_AUCTION_EVENTS_TOPIC=aieas.auction.events
KAFKA_ORDER_EVENTS_TOPIC=aieas.order.events
KAFKA_BID_BRIDGE_GROUP=aieas-bid-kafka-bridge
KAFKA_BID_RECORD_GROUP=aieas-bid-record-writers

MCP_READ_API_KEY=replace-with-a-strong-read-mcp-api-key
MCP_READ_ACTOR_ID=u_9001
MCP_READ_ACTOR_ROLE=admin
MCP_CONTROL_API_KEY=replace-with-a-strong-control-mcp-api-key
MCP_CONTROL_ACTOR_ID=u_9001
MCP_CONTROL_ACTOR_ROLE=admin

OBSERVABILITY_LOG_LEVEL=info
OBSERVABILITY_METRICS_PATH=/metrics
# Log format: text (dev/colorful) or json (prod, one line per record)
OBSERVABILITY_FORMAT=text
# GORM slow SQL threshold in milliseconds; set <=0 to disable
OBSERVABILITY_SLOW_SQL_THRESHOLD_MS=200

# Prometheus /metrics endpoint
OBSERVABILITY_METRICS_ENABLED=true
# Override observability.metrics.path; empty falls back to OBSERVABILITY_METRICS_PATH
OBSERVABILITY_METRICS_PATH_OVERRIDE=
OBSERVABILITY_METRICS_NAMESPACE=aieas
# When non-empty, require Authorization: Bearer <token> or X-Metrics-Token: <token>
OBSERVABILITY_METRICS_AUTH_TOKEN=

# OpenTelemetry tracing (disabled by default)
OBSERVABILITY_TRACING_ENABLED=false
# exporter: otlphttp | otlpgrpc | stdout | noop
OBSERVABILITY_TRACING_EXPORTER=otlphttp
OBSERVABILITY_TRACING_ENDPOINT=
OBSERVABILITY_TRACING_INSECURE=true
OBSERVABILITY_TRACING_SERVICE_NAME=aieas-backend
# sampler: always_on | always_off | traceidratio | parent_based_always_on | parent_based_traceid_ratio
OBSERVABILITY_TRACING_SAMPLER=parent_based_traceid_ratio
OBSERVABILITY_TRACING_SAMPLE_RATIO=1.0

# Health check paths
OBSERVABILITY_HEALTH_LIVENESS_PATH=/healthz
OBSERVABILITY_HEALTH_READINESS_PATH=/readyz

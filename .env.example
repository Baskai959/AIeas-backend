# Copy this file to .env for local development and replace values with real secrets.
# Do not commit .env.
#
# 约定：.env 只承载密钥/凭证类覆盖。端口、角色、MySQL/Redis 地址、限流、
# 超时、Kafka topic、开关等普通配置统一写在 configs/config.yaml。

# JWT 签名密钥；生产必须替换为高强度随机值。
JWT_SECRET=replace-with-a-strong-local-secret

# Redis RT 分片密码；地址、用户名、DB、连接池大小只在 configs/config.yaml 配置。
REDIS_RT_SHARD_0_PASSWORD=
REDIS_RT_SHARD_1_PASSWORD=
# 兼容老部署名；新部署优先使用 REDIS_RT_SHARD_0_PASSWORD。
REDIS_RT_PRIMARY_PASSWORD=

# Redis Cache 实例密码；地址、用户名、DB、连接池大小只在 configs/config.yaml 配置。
REDIS_CACHE_PASSWORD=

# 火山 TOS / 对象存储访问凭证；enabled、endpoint、bucket 等只在 configs/config.yaml 配置。
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# 直播分析回调鉴权 key；Agent URL、开关、超时只在 configs/config.yaml 配置。
AGENT_LIVE_ANALYSIS_CALLBACK_API_KEY=replace-with-a-strong-live-analysis-callback-key

# 豆包 TTS 凭证；voice 只在 configs/config.yaml 配置。
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACK_TOKEN=

# MCP API key；actorID / actorRole 只在 configs/config.yaml 配置。
MCP_READ_API_KEY=replace-with-a-strong-read-mcp-api-key
MCP_CONTROL_API_KEY=replace-with-a-strong-control-mcp-api-key

# /metrics 访问令牌；metrics path、namespace、enabled 等只在 configs/config.yaml 配置。
OBSERVABILITY_METRICS_AUTH_TOKEN=

{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "出价 WS ACK / RESULT / 队列监测面板使用的 Prometheus 数据源",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    { "id": 1, "type": "row", "title": "入口 · bid.place / ACK / accept / reject / result", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },
    {
      "id": 2,
      "type": "timeseries",
      "title": "入口出价与 ACK QPS",
      "description": "对齐入口 bid.place 路由模式与后端生成 bid.ack 的速率。async queued 接近入口 QPS 说明入口预校验与 Kafka 入队基本正常；rejected/unknown 上升需要看右侧拒绝与路由面板。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "axisLabel": "ops/s" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_place_mode_total[$__rate_interval])) by (mode)", "legendFormat": "place {{mode}}", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_ack_duration_seconds_count[$__rate_interval])) by (mode, result)", "legendFormat": "ack {{mode}}/{{result}}", "range": true, "refId": "B" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "accept / reject / queue-reject 流量",
      "description": "业务出价终态、显式拒绝原因和异步队列保护拒绝。用于判断入口错误来自业务校验、队列保护还是裁决结果。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "axisLabel": "ops/s" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum(rate(aieas_auction_bid_total[$__rate_interval])) by (result, reason)", "legendFormat": "bid {{result}}/{{reason}}", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "sum(rate(aieas_auction_bid_reject_total[$__rate_interval])) by (reason)", "legendFormat": "reject {{reason}}", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_queue_reject_total[$__rate_interval])) by (reason)", "legendFormat": "queue_reject {{reason}}", "range": true, "refId": "C" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "ACK 延迟 P95 / P99 / Avg",
      "description": "从收到 bid.place 到生成 bid.ack 并放入 WS outbound 的耗时。入口 ACK 变慢通常优先排查预校验、队列保护和 Kafka enqueue。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "axisLabel": "ms" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(aieas_bid_ack_duration_seconds_bucket[$__rate_interval])) by (le, mode, result)) * 1000", "legendFormat": "p95 {{mode}}/{{result}}", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "histogram_quantile(0.99, sum(rate(aieas_bid_ack_duration_seconds_bucket[$__rate_interval])) by (le, mode, result)) * 1000", "legendFormat": "p99 {{mode}}/{{result}}", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_ack_duration_seconds_sum[$__rate_interval])) by (mode, result) / clamp_min(sum(rate(aieas_bid_ack_duration_seconds_count[$__rate_interval])) by (mode, result), 0.001) * 1000", "legendFormat": "avg {{mode}}/{{result}}", "range": true, "refId": "C" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "出价路由决策 QPS",
      "description": "auction_bid_route_total 的 decision/reason 低基数路由视角，可定位 Go 侧预拒、same-price gate、Lua 进入与 Lua 拒绝等路径。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "axisLabel": "ops/s" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum(rate(aieas_auction_bid_route_total[$__rate_interval])) by (decision, reason)", "legendFormat": "{{decision}}/{{reason}}", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_command_publish_reject_total[$__rate_interval])) by (reason)", "legendFormat": "publish_reject {{reason}}", "range": true, "refId": "B" }
      ]
    },
    { "id": 6, "type": "row", "title": "异步队列 · Kafka / Worker Pool", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }, "panels": [] },
    {
      "id": 7,
      "type": "timeseries",
      "title": "pending queue 与 worker pool inflight",
      "description": "pending 表示异步出价待裁决/待 result ack 的全局积压；worker inflight 表示当前并发裁决 goroutine。pending 上升但 inflight 未打满，优先查 Kafka/消费；inflight 打满且延迟升高，优先查 Redis Lua/业务裁决。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "count" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "aieas_bid_pending_queue_size", "legendFormat": "pending", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "aieas_bid_worker_pool_inflight", "legendFormat": "worker_inflight", "range": true, "refId": "B" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Kafka partition lag",
      "description": "每个 Kafka partition 的 consumer lag。单 partition 持续升高可能是分区热点或该分区 worker/commit 变慢；所有 partition 升高通常是整体消费能力不足。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "messages" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum(aieas_bid_kafka_partition_lag) by (partition)", "legendFormat": "partition {{partition}}", "range": true, "refId": "A" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Worker commit lag P95 / P99",
      "description": "命令从 fetch 到实际 Kafka commit 的耗时。commit lag 增大通常说明批量 commit、worker 处理或回压链路变慢。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "axisLabel": "ms" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(aieas_bid_worker_commit_lag_seconds_bucket[$__rate_interval])) by (le)) * 1000", "legendFormat": "commit_lag p95", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "histogram_quantile(0.99, sum(rate(aieas_bid_worker_commit_lag_seconds_bucket[$__rate_interval])) by (le)) * 1000", "legendFormat": "commit_lag p99", "range": true, "refId": "B" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "异步链路分段延迟 P95",
      "description": "Kafka enqueue、worker decision、bid.result push 三段 P95。用于把 bid.result 端到端延迟拆到入口入队、裁决和结果推送。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "axisLabel": "ms" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(aieas_bid_kafka_enqueue_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000", "legendFormat": "kafka_enqueue p95", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(aieas_bid_decision_duration_seconds_bucket[$__rate_interval])) by (le, result)) * 1000", "legendFormat": "decision p95 {{result}}", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(aieas_bid_result_push_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000", "legendFormat": "result_push p95", "range": true, "refId": "C" }
      ]
    },
    { "id": 11, "type": "row", "title": "Redis Lua 裁决 · queue depth / roundtrip", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }, "panels": [] },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Redis Lua queue depth",
      "description": "客户端观测的 bid.lua 裁决 in-flight 深度，按 shard/instance/script 低基数维度聚合。深度持续升高说明 Redis Lua 裁决或 Redis client 等待发生拥塞。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "in-flight" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum(aieas_bid_lua_queue_depth) by (shard, instance, script)", "legendFormat": "{{shard}}/{{instance}}/{{script}}", "range": true, "refId": "A" }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Redis Lua roundtrip P95 / P99",
      "description": "bid.lua 客户端观测往返耗时，包含客户端等待与 Redis Lua 执行。按 shard/instance/script/status 聚合，status 不包含高基数标签。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "axisLabel": "ms" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(aieas_bid_lua_roundtrip_duration_seconds_bucket[$__rate_interval])) by (le, shard, instance, script, status)) * 1000", "legendFormat": "p95 {{shard}}/{{instance}}/{{script}}/{{status}}", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "histogram_quantile(0.99, sum(rate(aieas_bid_lua_roundtrip_duration_seconds_bucket[$__rate_interval])) by (le, shard, instance, script, status)) * 1000", "legendFormat": "p99 {{shard}}/{{instance}}/{{script}}/{{status}}", "range": true, "refId": "B" }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Lua 调用状态与 Redis Lua 错误 QPS",
      "description": "bid_lua_roundtrip 的 status 速率和 redis_lua_errors_total 的错误分类。noscript/busy/timeout/connection/error 上升时可快速区分脚本缓存、Redis 忙、超时和连接问题。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 43 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "axisLabel": "ops/s" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_lua_roundtrip_duration_seconds_count[$__rate_interval])) by (shard, instance, script, status)", "legendFormat": "roundtrip {{shard}}/{{instance}}/{{script}}/{{status}}", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "sum(rate(aieas_redis_lua_errors_total[$__rate_interval])) by (script, error)", "legendFormat": "redis_lua_error {{script}}/{{error}}", "range": true, "refId": "B" }
      ]
    },
    { "id": 15, "type": "row", "title": "bid.result 投递 · 终态 / 重试 / 延迟", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 }, "panels": [] },
    {
      "id": 16,
      "type": "timeseries",
      "title": "bid.result 端到端延迟 P95 / P99 / Avg",
      "description": "从 pending 入队到 bid.result 定向推送的端到端耗时，包含 Kafka、worker、Lua、事件转发和 WS 定向投递。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "axisLabel": "ms" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(aieas_bid_result_duration_seconds_bucket[$__rate_interval])) by (le, outcome)) * 1000", "legendFormat": "p95 {{outcome}}", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "histogram_quantile(0.99, sum(rate(aieas_bid_result_duration_seconds_bucket[$__rate_interval])) by (le, outcome)) * 1000", "legendFormat": "p99 {{outcome}}", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_result_duration_seconds_sum[$__rate_interval])) by (outcome) / clamp_min(sum(rate(aieas_bid_result_duration_seconds_count[$__rate_interval])) by (outcome), 0.001) * 1000", "legendFormat": "avg {{outcome}}", "range": true, "refId": "C" }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "bid.result / decision outcome QPS",
      "description": "bid.result 实际投递速率与 worker 裁决终态速率。decision outcome 高于 result 且 pending 上升时，优先查 result relay / WS 定向推送。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "axisLabel": "ops/s" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_result_duration_seconds_count[$__rate_interval])) by (outcome)", "legendFormat": "result {{outcome}}", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_decision_outcome_total[$__rate_interval])) by (outcome)", "legendFormat": "decision {{outcome}}", "range": true, "refId": "B" }
      ]
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "bid.result 投递耗时与 ACK 超时/重试",
      "description": "result_push 是服务端定向推送耗时；ack_timeout 表示客户端未及时确认 bid.result，可能触发重发或释放。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "axisLabel": "ms / ops/s" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(aieas_bid_result_push_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000", "legendFormat": "result_push p95 ms", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "histogram_quantile(0.99, sum(rate(aieas_bid_result_push_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000", "legendFormat": "result_push p99 ms", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "sum(rate(aieas_bid_result_ack_timeout_total[$__rate_interval]))", "legendFormat": "ack_timeout ops/s", "range": true, "refId": "C" }
      ]
    },
    { "id": 19, "type": "row", "title": "WebSocket · 连接 / 广播 / 慢客户端", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 68 }, "panels": [] },
    {
      "id": 20,
      "type": "timeseries",
      "title": "WS 连接数与连接事件",
      "description": "当前连接数和 connect/disconnect 事件速率。连接抖动会直接影响 ACK / result 到达率。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "axisLabel": "connections / ops/s" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "aieas_ws_connections", "legendFormat": "connections", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "sum(rate(aieas_ws_connection_total[$__rate_interval])) by (event)", "legendFormat": "{{event}}", "range": true, "refId": "B" }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "WS 广播延迟与 fanout",
      "description": "广播耗时 P95/P99 与 fanout 速率。广播慢而 result_push 正常，通常是房间广播路径或慢客户端拖累；二者同时升高则关注 Hub/网络。",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 69 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "axisLabel": "ms / fanout/s" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "histogram_quantile(0.95, sum(rate(aieas_ws_broadcast_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000", "legendFormat": "broadcast p95 ms", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "histogram_quantile(0.99, sum(rate(aieas_ws_broadcast_duration_seconds_bucket[$__rate_interval])) by (le)) * 1000", "legendFormat": "broadcast p99 ms", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "sum(rate(aieas_ws_broadcast_fanout_total[$__rate_interval]))", "legendFormat": "fanout/s", "range": true, "refId": "C" }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",

{
  "openapi": "3.0.3",
  "info": {
    "title": "AI直播助手 MCP 状态与权限接口",
    "version": "1.0.0",
    "description": "描述商家 AI 直播助手权限配置、MCP 控制审批回调，以及 WebSocket 推送事件。"
  },
  "paths": {
    "/api/v1/ai-assistant/permission": {
      "get": {
        "summary": "获取当前商家的 AI 控制权限",
        "tags": ["AI直播助手"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PermissionResponse" }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "更新当前商家的 AI 控制权限",
        "tags": ["AI直播助手"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/IdempotencyKey" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PermissionUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PermissionResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/ai-assistant/approvals/{requestId}/decision": {
      "post": {
        "summary": "商家确认或拒绝 AI 控制操作",
        "tags": ["AI直播助手"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "WebSocket ai.assistant.permission_request 事件中的 requestId"
          },
          { "$ref": "#/components/parameters/IdempotencyKey" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ApprovalDecisionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApprovalDecisionResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "schema": { "type": "string" },
        "description": "幂等键"
      }
    },
    "schemas": {
      "Envelope": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "example": 0 },
          "message": { "type": "string", "example": "success" },
          "trace_id": { "type": "string" },
          "data": { "type": "object" }
        }
      },
      "AIPermission": {
        "type": "string",
        "enum": ["ASK", "ALLOW", "DENY"],
        "description": "ASK=执行控制 MCP 前询问商家；ALLOW=自动允许；DENY=自动拒绝"
      },
      "PermissionUpdateRequest": {
        "type": "object",
        "required": ["permission"],
        "properties": {
          "permission": { "$ref": "#/components/schemas/AIPermission" }
        }
      },
      "PermissionResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/Envelope" },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "permission": { "$ref": "#/components/schemas/AIPermission" }
                }
              }
            }
          }
        ]
      },
      "ApprovalDecisionRequest": {
        "type": "object",
        "required": ["approved"],
        "properties": {
          "approved": { "type": "boolean", "description": "true=允许执行；false=拒绝执行" }
        }
      },
      "ApprovalDecisionResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/Envelope" },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "requestId": { "type": "string" },
                  "approved": { "type": "boolean" },
                  "message": { "type": "string" },
                  "decidedAt": { "type": "string", "format": "date-time" },
                  "liveSessionId": { "type": "integer", "format": "uint64" }
                }
              }
            }
          }
        ]
      },
      "AIAssistantWebSocketEvent": {
        "type": "object",
        "description": "通过 /ws/live-sessions/{sessionId} 推送。外层 type 为 ai.assistant.status、ai.assistant.permission_request 或 ai.assistant.broadcast。",
        "properties": {
          "eventId": { "type": "string" },
          "kind": { "type": "string", "enum": ["status", "permission", "broadcast"] },
          "status": { "type": "string", "example": "pending" },
          "toolName": { "type": "string", "example": "operate_live_session_lot" },
          "merchantId": { "type": "string" },
          "liveSessionId": { "type": "integer", "format": "uint64" },
          "requestId": { "type": "string" },
          "permission": { "$ref": "#/components/schemas/AIPermission" },
          "message": { "type": "string", "example": "AI 请求开始讲解拍品 91001，是否允许执行？" },
          "broadcastText": { "type": "string", "example": "请大家关注当前拍品细节。" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}

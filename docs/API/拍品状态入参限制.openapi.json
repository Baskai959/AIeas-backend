{
  "openapi": "3.0.3",
  "info": {
    "title": "拍品状态入参限制",
    "version": "v1",
    "description": "仅包含拍品创建、拍品编辑接口的 status 入参限制变更。创建和编辑拍品时，status 只允许 DRAFT 或 PENDING_AUDIT；READY 只能通过后台审核接口产生。"
  },
  "servers": [
    {
      "url": "http://localhost:8888",
      "description": "Local"
    }
  ],
  "tags": [
    {
      "name": "Auction",
      "description": "拍品与拍卖管理"
    }
  ],
  "paths": {
    "/api/v1/auctions": {
      "post": {
        "tags": [
          "Auction"
        ],
        "summary": "创建拍品",
        "description": "需要 merchant 或 admin 角色。status 只能传 DRAFT 或 PENDING_AUDIT；不传默认 DRAFT。不能通过该接口直接创建 READY 拍品。",
        "operationId": "createAuctionStatusRestricted",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuctionCreateRequest"
              },
              "example": {
                "itemId": 1001,
                "auctionType": "ENGLISH",
                "startPrice": 1000,
                "reservePrice": 50000,
                "depositAmount": 20000,
                "incrementRule": {
                  "type": "ladder",
                  "steps": [
                    {
                      "min": 0,
                      "max": 10000,
                      "amount": 1000
                    },
                    {
                      "min": 10000,
                      "amount": 5000
                    }
                  ]
                },
                "antiSnipingSec": 15,
                "antiExtendSec": 30,
                "status": "PENDING_AUDIT",
                "startTime": "2026-06-01T05:57:54.000Z",
                "endTime": "2026-06-03T05:57:49.000Z"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功"
          },
          "400": {
            "description": "参数不合法，例如 status 传 READY/RUNNING/CLOSED_* 等非草稿或待审核状态"
          }
        }
      }
    },
    "/api/v1/auctions/{id}": {
      "patch": {
        "tags": [
          "Auction"
        ],
        "summary": "编辑拍品",
        "description": "需要 merchant 或 admin 角色。status 字段如需传入，只允许 DRAFT 或 PENDING_AUDIT；不能通过编辑接口将拍品改为 READY。",
        "operationId": "updateAuctionStatusRestricted",
        "parameters": [
          {
            "$ref": "#/components/parameters/AuctionIDPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuctionPatchRequest"
              },
              "example": {
                "status": "PENDING_AUDIT",
                "reservePrice": 50000
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "编辑成功"
          },
          "400": {
            "description": "参数不合法，例如 status 传 READY/RUNNING/CLOSED_* 等非草稿或待审核状态"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "AuctionIDPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "uint64",
          "minimum": 1
        },
        "description": "拍品 ID"
      }
    },
    "schemas": {
      "EditableAuctionStatus": {
        "type": "string",
        "enum": [
          "DRAFT",
          "PENDING_AUDIT"
        ],
        "description": "创建/编辑拍品接口允许传入的状态。READY 只能由后台审核接口生成。"
      },
      "AuctionCreateRequest": {
        "type": "object",
        "required": [
          "itemId"
        ],
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "可选；不传由服务端生成"
          },
          "itemId": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1
          },
          "auctionType": {
            "type": "string",
            "enum": [
              "ENGLISH"
            ],
            "default": "ENGLISH"
          },
          "startPrice": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "incrementRule": {
            "type": "object",
            "description": "固定加价 fixed 或阶梯加价 ladder，详见拍品加价规则变更文档"
          },
          "antiSnipingSec": {
            "type": "integer",
            "minimum": 1,
            "default": 15
          },
          "antiExtendSec": {
            "type": "integer",
            "minimum": 1,
            "default": 30
          },
          "status": {
            "$ref": "#/components/schemas/EditableAuctionStatus"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AuctionPatchRequest": {
        "type": "object",
        "properties": {
          "startPrice": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "incrementRule": {
            "type": "object",
            "description": "固定加价 fixed 或阶梯加价 ladder，详见拍品加价规则变更文档"
          },
          "antiSnipingSec": {
            "type": "integer",
            "minimum": 1
          },
          "antiExtendSec": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "$ref": "#/components/schemas/EditableAuctionStatus"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}

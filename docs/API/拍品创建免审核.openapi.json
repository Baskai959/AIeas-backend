{
  "openapi": "3.0.3",
  "info": {
    "title": "拍品创建免审核",
    "version": "1.0.0",
    "description": "拍品创建后不再进入审核流程。商家或管理员创建拍品时，status 不传默认 READY；如需先保存草稿可传 DRAFT。创建/编辑接口不再允许写入 PENDING_AUDIT，READY 可由创建接口或草稿编辑接口直接产生。"
  },
  "paths": {
    "/api/v1/auctions": {
      "post": {
        "tags": [
          "拍品"
        ],
        "summary": "创建拍品（免审核）",
        "description": "需要 merchant 或 admin 角色。创建成功后不需要后台审核；status 不传时默认 READY，可直接进入开拍/上架前置流程。status 只允许 DRAFT 或 READY；PENDING_AUDIT、RUNNING、CLOSED_* 等状态会返回参数错误。",
        "operationId": "createAuctionWithoutAudit",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAuctionRequest"
              },
              "examples": {
                "readyByDefault": {
                  "summary": "不传 status，默认 READY",
                  "value": {
                    "itemId": 1001,
                    "auctionType": "ENGLISH",
                    "startPrice": 1000,
                    "reservePrice": 5000,
                    "capPrice": 10000,
                    "depositAmount": 2000,
                    "incrementRule": {
                      "type": "fixed",
                      "amount": 100,
                      "maxBidSteps": 5
                    },
                    "antiSnipingSec": 15,
                    "antiExtendSec": 30,
                    "antiExtendMode": "ADD",
                    "durationSec": 1800
                  }
                },
                "draft": {
                  "summary": "创建为草稿",
                  "value": {
                    "itemId": 1001,
                    "auctionType": "ENGLISH",
                    "startPrice": 1000,
                    "reservePrice": 5000,
                    "capPrice": 10000,
                    "depositAmount": 2000,
                    "status": "DRAFT",
                    "incrementRule": {
                      "type": "ladder",
                      "steps": [
                        {
                          "min": 0,
                          "max": 50000,
                          "amount": 1000
                        },
                        {
                          "min": 50000,
                          "amount": 5000
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功；未传 status 时 data.status 为 READY。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuctionResponse"
                }
              }
            }
          },
          "400": {
            "description": "参数错误，例如 status=PENDING_AUDIT/RUNNING/CLOSED_WON。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auctions/{id}": {
      "patch": {
        "tags": [
          "拍品"
        ],
        "summary": "编辑拍品（免审核）",
        "description": "需要 merchant 或 admin 角色。未开拍前可编辑 DRAFT/READY/PENDING_AUDIT 存量拍品内容；status 字段如需传入，只允许 DRAFT 或 READY，不能通过该接口写入 PENDING_AUDIT 或运行/成交状态。",
        "operationId": "updateAuctionWithoutAudit",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAuctionRequest"
              },
              "example": {
                "status": "READY",
                "startPrice": 1000,
                "reservePrice": 5000,
                "capPrice": 10000,
                "incrementRule": {
                  "type": "fixed",
                  "amount": 100,
                  "maxBidSteps": 5
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "编辑成功。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuctionResponse"
                }
              }
            }
          },
          "400": {
            "description": "参数错误，例如 status=PENDING_AUDIT/RUNNING/CLOSED_WON。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "状态不允许编辑，例如拍品已开拍或已成交。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "CreateAuctionRequest": {
        "type": "object",
        "required": [
          "itemId",
          "startPrice",
          "reservePrice",
          "capPrice",
          "incrementRule"
        ],
        "properties": {
          "itemId": {
            "type": "integer",
            "format": "uint64"
          },
          "liveRoomId": {
            "type": "integer",
            "format": "uint64"
          },
          "auctionType": {
            "type": "string",
            "enum": [
              "ENGLISH"
            ],
            "default": "ENGLISH"
          },
          "startPrice": {
            "type": "integer",
            "format": "int64",
            "description": "起拍价，单位分。"
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64",
            "description": "保留价，单位分。"
          },
          "capPrice": {
            "type": "integer",
            "format": "int64",
            "description": "封顶价，单位分。"
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64",
            "description": "保证金，单位分。"
          },
          "incrementRule": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/FixedIncrementRule"
              },
              {
                "$ref": "#/components/schemas/LadderIncrementRule"
              }
            ]
          },
          "antiSnipingSec": {
            "type": "integer",
            "default": 15
          },
          "antiExtendSec": {
            "type": "integer",
            "default": 30
          },
          "antiExtendMode": {
            "type": "string",
            "enum": [
              "ADD",
              "RESET"
            ],
            "default": "ADD"
          },
          "status": {
            "$ref": "#/components/schemas/WritableAuctionStatus"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "durationSec": {
            "type": "integer"
          }
        }
      },
      "UpdateAuctionRequest": {
        "type": "object",
        "properties": {
          "startPrice": {
            "type": "integer",
            "format": "int64"
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64"
          },
          "capPrice": {
            "type": "integer",
            "format": "int64"
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64"
          },
          "incrementRule": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/FixedIncrementRule"
              },
              {
                "$ref": "#/components/schemas/LadderIncrementRule"
              }
            ]
          },
          "antiSnipingSec": {
            "type": "integer"
          },
          "antiExtendSec": {
            "type": "integer"
          },
          "antiExtendMode": {
            "type": "string",
            "enum": [
              "ADD",
              "RESET"
            ]
          },
          "status": {
            "$ref": "#/components/schemas/WritableAuctionStatus"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "durationSec": {
            "type": "integer"
          }
        }
      },
      "WritableAuctionStatus": {
        "type": "string",
        "enum": [
          "DRAFT",
          "READY"
        ],
        "default": "READY",
        "description": "拍品创建/编辑接口允许写入的状态。PENDING_AUDIT 已不再用于新拍品。"
      },
      "FixedIncrementRule": {
        "type": "object",
        "required": [
          "type",
          "amount",
          "maxBidSteps"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "fixed"
            ]
          },
          "amount": {
            "type": "integer",
            "format": "int64"
          },
          "maxBidSteps": {
            "type": "integer"
          }
        }
      },
      "LadderIncrementRule": {
        "type": "object",
        "required": [
          "type",
          "steps"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ladder"
            ]
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LadderIncrementStep"
            }
          }
        }
      },
      "LadderIncrementStep": {
        "type": "object",
        "required": [
          "min",
          "amount"
        ],
        "properties": {
          "min": {
            "type": "integer",
            "format": "int64"
          },
          "max": {
            "type": "integer",
            "format": "int64"
          },
          "amount": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "Auction": {
        "type": "object",
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "uint64"
          },
          "itemId": {
            "type": "integer",
            "format": "uint64"
          },
          "sellerId": {
            "type": "string"
          },
          "liveRoomId": {
            "type": "integer",
            "format": "uint64"
          },
          "auctionType": {
            "type": "string"
          },
          "startPrice": {
            "type": "integer",
            "format": "int64"
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64"
          },
          "capPrice": {
            "type": "integer",
            "format": "int64"
          },
          "incrementRule": {
            "type": "object"
          },
          "antiSnipingSec": {
            "type": "integer"
          },
          "antiExtendSec": {
            "type": "integer"
          },
          "antiExtendMode": {
            "type": "string"
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64"
          },
          "status": {
            "type": "string"
          },
          "ruleSnapshot": {
            "type": "object"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "durationSec": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AuctionResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/Auction"
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "nullable": true
          },
          "trace_id": {
            "type": "string"
          }
        }
      }
    }
  }
}

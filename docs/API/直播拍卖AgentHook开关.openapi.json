{
  "openapi": "3.0.3",
  "info": {
    "title": "直播拍卖 Agent Hook 开关接口",
    "version": "v1",
    "description": "商家可按直播间查询或设置本商家的直播拍卖 AI Agent hook 开关。开关开启后，后端会在开播、拍品上架、拍品下架、落锤成交、最高出价变化时向 Agent hook 函数传递一条中文事件字符串。"
  },
  "servers": [
    {
      "url": "http://localhost:8888",
      "description": "Local"
    }
  ],
  "tags": [
    {
      "name": "LiveRoomAgentHook",
      "description": "直播拍卖 AI Agent hook 开关"
    }
  ],
  "paths": {
    "/api/v1/live-rooms/{id}/agent-hook": {
      "get": {
        "tags": [
          "LiveRoomAgentHook"
        ],
        "summary": "查询直播拍卖 Agent Hook 开关",
        "description": "需要 merchant 或 admin 角色。merchant 只能查询自己的直播间；admin 可查询任意直播间。返回值按商家维度生效，同一个商家的直播间共享该开关。",
        "operationId": "getLiveRoomAgentHookConfig",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "直播间 ID。",
            "schema": {
              "type": "integer",
              "format": "uint64",
              "example": 90001
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/LiveAgentHookConfig"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "enabled": true
                  },
                  "trace_id": "req_1710000000000000000"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "tags": [
          "LiveRoomAgentHook"
        ],
        "summary": "设置直播拍卖 Agent Hook 开关",
        "description": "需要 merchant 或 admin 角色。merchant 只能设置自己的直播间；admin 可设置任意直播间。该设置按商家维度存储，开启后事件字符串会投递给 Agent hook。",
        "operationId": "updateLiveRoomAgentHookConfig",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "直播间 ID。",
            "schema": {
              "type": "integer",
              "format": "uint64",
              "example": 90001
            }
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "description": "幂等键，同一次设置请求保持一致。",
            "schema": {
              "type": "string",
              "example": "set-live-agent-hook-90001-true-001"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateLiveAgentHookConfigRequest"
              },
              "example": {
                "enabled": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "设置成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/LiveAgentHookConfig"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "enabled": true
                  },
                  "trace_id": "req_1710000000000000000"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "trace_id": {
            "type": "string",
            "example": "req_1710000000000000000"
          }
        },
        "required": [
          "code",
          "message"
        ]
      },
      "LiveAgentHookConfig": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "是否开启直播拍卖 AI Agent hook。",
            "example": true
          }
        },
        "required": [
          "enabled"
        ]
      },
      "UpdateLiveAgentHookConfigRequest": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "是否开启直播拍卖 AI Agent hook。",
            "example": true
          }
        },
        "required": [
          "enabled"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 20001
          },
          "message": {
            "type": "string",
            "example": "参数不合法"
          },
          "trace_id": {
            "type": "string",
            "example": "req_1710000000000000000"
          }
        },
        "required": [
          "code",
          "message"
        ]
      }
    },
    "responses": {
      "BadRequest": {
        "description": "请求参数错误",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "无权限操作该直播间",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "直播间不存在",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}

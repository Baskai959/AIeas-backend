{
  "openapi": "3.0.3",
  "info": {
    "title": "直播场次去直播间维度接口",
    "version": "1.0.0",
    "description": "最新直播拍卖主链路只保留 live_session 维度：商家可创建多个直播场次，开播、下播、挂载拍品、取消讲解、开拍、统计、封面上传、AI Agent Hook 与 WebSocket 都以 liveSessionId 为唯一业务维度。旧 /api/v1/live-rooms 与 /ws/live-rooms 已删除。"
  },
  "servers": [
    { "url": "http://localhost:3030" }
  ],
  "tags": [
    { "name": "LiveSessions", "description": "直播场次" },
    { "name": "LiveSessionWS", "description": "直播场次 WebSocket" }
  ],
  "paths": {
    "/api/v1/live-sessions": {
      "get": {
        "tags": ["LiveSessions"],
        "summary": "查询直播场次列表",
        "parameters": [
          { "name": "merchantId", "in": "query", "required": false, "schema": { "type": "string" }, "description": "商家 ID。merchant 角色会被后端强制改为当前登录商家。" },
          { "name": "status", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/LiveSessionStatus" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "default": 20, "minimum": 1, "maximum": 100 } },
          { "name": "offset", "in": "query", "required": false, "schema": { "type": "integer", "default": 0, "minimum": 0 } }
        ],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionListResponse" } } } } }
      },
      "post": {
        "tags": ["LiveSessions"],
        "summary": "创建直播场次",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionCreateRequest" } } } },
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionResponse" } } } } }
      }
    },
    "/api/v1/live-sessions/{id}": {
      "get": {
        "tags": ["LiveSessions"],
        "summary": "查询直播场次详情",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionResponse" } } } } }
      },
      "patch": {
        "tags": ["LiveSessions"],
        "summary": "编辑直播场次",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionPatchRequest" } } } },
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionResponse" } } } } }
      }
    },
    "/api/v1/live-sessions/{id}/start": {
      "post": {
        "tags": ["LiveSessions"],
        "summary": "开播",
        "description": "同一商家同时只能有一个 LIVE 场次。",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionResponse" } } } } }
      }
    },
    "/api/v1/live-sessions/{id}/end": {
      "post": {
        "tags": ["LiveSessions"],
        "summary": "下播",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionResponse" } } } } }
      }
    },
    "/api/v1/live-sessions/{id}/lots": {
      "get": {
        "tags": ["LiveSessions"],
        "summary": "查询本场拍品",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuctionLotListResponse" } } } } }
      },
      "post": {
        "tags": ["LiveSessions"],
        "summary": "挂载拍品到直播场次",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MountLotRequest" } } } },
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MountLotResponse" } } } } }
      }
    },
    "/api/v1/live-sessions/{id}/lots/{auctionId}": {
      "delete": {
        "tags": ["LiveSessions"],
        "summary": "从直播场次移除拍品",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "$ref": "#/components/parameters/AuctionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/v1/live-sessions/{id}/activate": {
      "post": {
        "tags": ["LiveSessions"],
        "summary": "开始讲解/开拍本场拍品",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ActivateLotRequest" } } } },
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuctionLotResponse" } } } } }
      }
    },
    "/api/v1/live-sessions/{id}/deactivate": {
      "post": {
        "tags": ["LiveSessions"],
        "summary": "取消讲解",
        "description": "取消当前 active 拍品讲解，非终态拍品回到 READY，可重新开始拍卖。",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionResponse" } } } } }
      }
    },
    "/api/v1/live-sessions/{id}/stats": {
      "get": {
        "tags": ["LiveSessions"],
        "summary": "查询本场实时统计",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionStatsResponse" } } } } }
      }
    },
    "/api/v1/live-sessions/{id}/bids": {
      "get": {
        "tags": ["LiveSessions"],
        "summary": "查询本场出价记录",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/v1/live-sessions/{id}/orders": {
      "get": {
        "tags": ["LiveSessions"],
        "summary": "查询本场订单",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }, { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/v1/live-sessions/{id}/cover": {
      "post": {
        "tags": ["LiveSessions"],
        "summary": "上传直播场次封面",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "type": "object", "required": ["image"], "properties": { "image": { "type": "string", "format": "binary" } } } } } },
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionResponse" } } } } }
      }
    },
    "/api/v1/live-sessions/{id}/agent-hook": {
      "get": {
        "tags": ["LiveSessions"],
        "summary": "查询 AI Agent Hook 开关",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentHookConfigResponse" } } } } }
      },
      "patch": {
        "tags": ["LiveSessions"],
        "summary": "设置 AI Agent Hook 开关",
        "description": "开启时触发一次 Hook：直播场次{id}AI直播助手已开启；关闭只更新配置，不触发 Hook。",
        "parameters": [{ "$ref": "#/components/parameters/LiveSessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentHookPatchRequest" } } } },
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgentHookConfigResponse" } } } } }
      }
    },
    "/ws/live-sessions/{sessionId}": {
      "get": {
        "tags": ["LiveSessionWS"],
        "summary": "连接直播场次 WebSocket",
        "description": "后端按 liveSessionId 查询当前 activeAuctionId；若当前无在拍品，Upgrade 前返回 409。",
        "parameters": [{ "name": "sessionId", "in": "path", "required": true, "schema": { "type": "integer", "format": "uint64" } }],
        "responses": {
          "101": { "description": "Switching Protocols" },
          "409": { "description": "直播场次当前无在拍品" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "LiveSessionId": { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "uint64" }, "description": "直播场次 ID" },
      "AuctionId": { "name": "auctionId", "in": "path", "required": true, "schema": { "type": "integer", "format": "uint64" }, "description": "拍品 ID" },
      "IdempotencyKey": { "name": "Idempotency-Key", "in": "header", "required": true, "schema": { "type": "string" }, "description": "写接口幂等键" }
    },
    "schemas": {
      "LiveSessionStatus": { "type": "string", "enum": ["DRAFT", "SCHEDULED", "LIVE", "ENDED", "CANCELLED"] },
      "LiveSessionCreateRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "merchantId": { "type": "string", "description": "admin 可指定；merchant 会被后端覆盖为当前用户" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "coverUrl": { "type": "string" },
          "status": { "$ref": "#/components/schemas/LiveSessionStatus" },
          "scheduledStartTime": { "type": "string", "format": "date-time", "nullable": true },
          "plannedDurationSec": { "type": "integer", "minimum": 0 }
        }
      },
      "LiveSessionPatchRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "coverUrl": { "type": "string" },
          "status": { "$ref": "#/components/schemas/LiveSessionStatus" },
          "scheduledStartTime": { "type": "string", "format": "date-time", "nullable": true },
          "plannedDurationSec": { "type": "integer", "minimum": 0 }
        }
      },
      "LiveSession": {
        "allOf": [
          { "$ref": "#/components/schemas/LiveSessionCreateRequest" },
          {
            "type": "object",
            "properties": {
              "id": { "type": "integer", "format": "uint64" },
              "merchantId": { "type": "string" },
              "activeAuctionId": { "type": "integer", "format": "uint64" },
              "openedAt": { "type": "string", "format": "date-time", "nullable": true },
              "closedAt": { "type": "string", "format": "date-time", "nullable": true },
              "lotsTotal": { "type": "integer" },
              "lotsSold": { "type": "integer" },
              "lotsUnsold": { "type": "integer" },
              "bidCount": { "type": "integer" },
              "gmvCent": { "type": "integer", "format": "int64" },
              "viewerPeak": { "type": "integer" },
              "viewerTotal": { "type": "integer" },
              "createdAt": { "type": "string", "format": "date-time" },
              "updatedAt": { "type": "string", "format": "date-time" }
            }
          }
        ]
      },
      "AuctionLot": {
        "type": "object",
        "properties": {
          "auctionId": { "type": "integer", "format": "uint64" },
          "itemId": { "type": "integer", "format": "uint64" },
          "sellerId": { "type": "string" },
          "liveSessionId": { "type": "integer", "format": "uint64", "nullable": true },
          "status": { "type": "string" },
          "startPrice": { "type": "integer", "format": "int64" },
          "currentPrice": { "type": "integer", "format": "int64" }
        }
      },
      "MountLotRequest": { "type": "object", "required": ["auctionId"], "properties": { "auctionId": { "type": "integer", "format": "uint64" } } },
      "ActivateLotRequest": { "type": "object", "required": ["auctionId"], "properties": { "auctionId": { "type": "integer", "format": "uint64" }, "durationSec": { "type": "integer", "minimum": 0 } } },
      "AgentHookPatchRequest": { "type": "object", "required": ["enabled"], "properties": { "enabled": { "type": "boolean" } } },
      "LiveSessionStats": {
        "type": "object",
        "properties": {
          "liveSessionId": { "type": "integer", "format": "uint64" },
          "online": { "type": "integer" },
          "lotsTotal": { "type": "integer" },
          "lotsSold": { "type": "integer" },
          "lotsUnsold": { "type": "integer" },
          "bidCount": { "type": "integer" },
          "gmvCent": { "type": "integer", "format": "int64" },
          "activeAuctionId": { "type": "integer", "format": "uint64" },
          "currentPrice": { "type": "integer", "format": "int64" },
          "currentBidCount": { "type": "integer" },
          "currentRemainSeconds": { "type": "integer", "format": "int64" }
        }
      },
      "AgentHookConfig": { "type": "object", "properties": { "enabled": { "type": "boolean" } } },
      "LiveSessionResponse": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "data": { "$ref": "#/components/schemas/LiveSession" } } },
      "LiveSessionListResponse": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "data": { "type": "object", "properties": { "sessions": { "type": "array", "items": { "$ref": "#/components/schemas/LiveSession" } } } } } },
      "AuctionLotResponse": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "data": { "$ref": "#/components/schemas/AuctionLot" } } },
      "AuctionLotListResponse": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "data": { "type": "object", "properties": { "lots": { "type": "array", "items": { "$ref": "#/components/schemas/AuctionLot" } } } } } },
      "MountLotResponse": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "data": { "type": "object", "properties": { "lot": { "$ref": "#/components/schemas/AuctionLot" } } } } },
      "LiveSessionStatsResponse": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "data": { "$ref": "#/components/schemas/LiveSessionStats" } } },
      "AgentHookConfigResponse": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "data": { "$ref": "#/components/schemas/AgentHookConfig" } } }
    }
  }
}

{
  "openapi": "3.0.3",
  "info": {
    "title": "直播间取消讲解可重新开拍",
    "version": "1.0.0",
    "description": "说明直播间取消当前拍品讲解接口的最新语义：取消讲解不再落槌，不生成成交/流拍结果，非终态拍品回到 READY，可重新开始拍卖或手动下架。"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/api/v1/live-rooms/{id}/deactivate": {
      "post": {
        "tags": [
          "LiveRooms"
        ],
        "summary": "取消当前拍品讲解",
        "description": "需要 merchant 或 admin 角色，并要求 Idempotency-Key。该接口只取消直播间当前 active 拍品的讲解：释放 activeAuctionId 和房间锁；若拍品处于 READY/WARMING_UP/RUNNING/EXTENDED/HAMMER_PENDING，则退回 READY，允许后续重新开始拍卖或下架。该接口不执行落槌，不关闭直播场次，不生成订单，不把拍品改为 CLOSED_WON/CLOSED_FAILED。",
        "operationId": "deactivateLiveRoomAuction",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64"
            },
            "description": "直播间 ID"
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "幂等键"
          }
        ],
        "responses": {
          "200": {
            "description": "取消讲解成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LiveRoomResponse"
                },
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "id": 90001,
                    "merchantId": "m_1",
                    "title": "直播间",
                    "status": "LIVE",
                    "createdAt": "2026-05-29T10:00:00Z",
                    "updatedAt": "2026-05-29T10:10:00Z"
                  },
                  "trace_id": "req_1780000000000000000"
                }
              }
            }
          },
          "400": {
            "description": "参数不合法"
          },
          "403": {
            "description": "无权限操作该直播间"
          },
          "404": {
            "description": "直播间或拍品不存在"
          },
          "409": {
            "description": "状态不允许，例如 active 拍品已经成交且不能通过取消讲解回退"
          }
        }
      }
    },
    "/api/v1/live-rooms/{id}/lots/{auctionId}": {
      "delete": {
        "tags": [
          "LiveRooms"
        ],
        "summary": "从直播间下架拍品",
        "description": "取消讲解后回到 READY 的拍品可以下架；已经成交的 CLOSED_WON/SETTLED 拍品不能下架，会保留在直播场次记录中。",
        "operationId": "unmountLiveRoomAuctionAfterDeactivateRule",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64"
            },
            "description": "直播间 ID"
          },
          {
            "name": "auctionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "uint64"
            },
            "description": "拍品 ID"
          }
        ],
        "responses": {
          "200": {
            "description": "下架成功",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "deleted": true
                  },
                  "trace_id": "req_1780000000000000001"
                }
              }
            }
          },
          "409": {
            "description": "当前 active 拍品或已成交拍品不允许下架"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LiveRoomResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/LiveRoom"
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "LiveRoom": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64"
          },
          "merchantId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "coverUrl": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "OFFLINE",
              "LIVE",
              "CLOSED"
            ]
          },
          "activeAuctionId": {
            "type": "integer",
            "format": "uint64"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}

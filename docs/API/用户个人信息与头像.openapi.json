{
  "openapi": "3.0.3",
  "info": {
    "title": "用户个人信息与头像接口",
    "version": "v1",
    "description": "用户编辑个人昵称，以及通过 multipart/form-data 上传头像图片。头像上传复用后端对象存储与 /api/v1/images/{key} 图片代理读取链路。"
  },
  "servers": [
    {
      "url": "http://localhost:8888",
      "description": "Local"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "登录、当前用户与个人资料"
    }
  ],
  "paths": {
    "/api/v1/auth/me": {
      "patch": {
        "tags": [
          "Auth"
        ],
        "summary": "编辑当前用户个人信息",
        "description": "需要登录。当前仅支持编辑 nickname，服务端会去除首尾空白，昵称不能为空且不超过 64 个字符。",
        "operationId": "updateCurrentUserProfile",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileRequest"
              },
              "example": {
                "nickname": "新昵称001"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功，返回当前用户资料。",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/UserProfile"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "id": "u_1001",
                    "nickname": "新昵称001",
                    "avatarUrl": "/api/v1/images/8f2c1f0a9d4b4b66.jpg",
                    "role": "buyer",
                    "status": "ACTIVE"
                  },
                  "trace_id": "req_1710000000000000000"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/api/v1/auth/me/avatar": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "上传当前用户头像",
        "description": "需要登录。请求体为 multipart/form-data，文件字段名为 avatar；兼容 image 字段。服务端上传对象存储后将返回的 /api/v1/images/{key} 代理 URL 写入 user.avatar_url。",
        "operationId": "uploadCurrentUserAvatar",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/AvatarUploadRequest"
              },
              "encoding": {
                "avatar": {
                  "contentType": "image/*"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "上传成功，返回更新后的当前用户资料。",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/UserProfile"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "id": "u_1001",
                    "nickname": "新昵称001",
                    "avatarUrl": "/api/v1/images/8f2c1f0a9d4b4b66.jpg",
                    "role": "buyer",
                    "status": "ACTIVE"
                  },
                  "trace_id": "req_1710000000000000000"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "description": "幂等键，同一次写请求保持一致。",
        "schema": {
          "type": "string",
          "example": "profile-update-u_1001-001"
        }
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "trace_id": {
            "type": "string",
            "example": "req_1710000000000000000"
          }
        }
      },
      "UpdateProfileRequest": {
        "type": "object",
        "required": [
          "nickname"
        ],
        "properties": {
          "nickname": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "description": "昵称，服务端去除首尾空白后保存。",
            "example": "新昵称001"
          }
        }
      },
      "AvatarUploadRequest": {
        "type": "object",
        "required": [
          "avatar"
        ],
        "properties": {
          "avatar": {
            "type": "string",
            "format": "binary",
            "description": "头像图片文件，字段名 avatar；兼容 image 字段。"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "required": [
          "id",
          "nickname",
          "role"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "u_1001"
          },
          "nickname": {
            "type": "string",
            "example": "新昵称001"
          },
          "avatarUrl": {
            "type": "string",
            "description": "头像代理 URL；浏览器通过 GET /api/v1/images/{key} 读取头像图片。",
            "example": "/api/v1/images/8f2c1f0a9d4b4b66.jpg"
          },
          "role": {
            "type": "string",
            "enum": [
              "buyer",
              "merchant",
              "admin"
            ],
            "example": "buyer"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "DISABLED"
            ],
            "example": "ACTIVE"
          },
          "aiPermission": {
            "type": "string",
            "enum": [
              "ASK",
              "ALLOW",
              "DENY"
            ],
            "example": "ASK"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "nullable": true
          },
          "trace_id": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "参数不合法",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "code": 20001,
              "message": "参数不合法",
              "data": null,
              "trace_id": "req_1710000000000000000"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "缺少访问令牌或令牌无效",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "code": 10002,
              "message": "访问令牌无效或已过期",
              "data": null,
              "trace_id": "req_1710000000000000000"
            }
          }
        }
      },
      "Forbidden": {
        "description": "账号停用或无访问权限",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "code": 10005,
              "message": "账号已停用",
              "data": null,
              "trace_id": "req_1710000000000000000"
            }
          }
        }
      },
      "Conflict": {
        "description": "幂等键冲突",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "code": 20012,
              "message": "资源冲突",
              "data": null,
              "trace_id": "req_1710000000000000000"
            }
          }
        }
      },
      "ServiceUnavailable": {
        "description": "对象存储未启用或暂不可用",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "code": 90002,
              "message": "服务暂不可用",
              "data": null,
              "trace_id": "req_1710000000000000000"
            }
          }
        }
      }
    }
  }
}

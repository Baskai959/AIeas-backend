{
  "openapi": "3.0.3",
  "info": {
    "title": "直播间拍品自动上架",
    "version": "1.0.0",
    "description": "新增拍品自动上架接口。前端只传 auctionId，后端根据拍品 sellerId 自动找到该商家的直播间并挂载。"
  },
  "paths": {
    "/api/v1/live-rooms/lots": {
      "post": {
        "tags": [
          "直播间"
        ],
        "summary": "自动上架拍品到商家直播间",
        "description": "需要 merchant 或 admin 角色，并要求 Idempotency-Key。请求体只需要 auctionId；后端会读取拍品归属商家，并自动挂载到该商家的直播间。若商家没有直播间返回 404；若拍品已挂入其他直播间返回 409。",
        "operationId": "autoMountAuctionToLiveRoom",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "幂等键，同一次上架操作保持一致。"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AutoMountLotRequest"
              },
              "example": {
                "auctionId": 110010001
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "上架成功，返回挂载后的拍品。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AutoMountLotResponse"
                }
              }
            }
          },
          "400": {
            "description": "参数错误，例如 auctionId 为空。"
          },
          "403": {
            "description": "无权限上架该拍品。"
          },
          "404": {
            "description": "拍品或商家直播间不存在。"
          },
          "409": {
            "description": "拍品状态不允许上架，或已挂入其他直播间。"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "AutoMountLotRequest": {
        "type": "object",
        "required": [
          "auctionId"
        ],
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "uint64",
            "description": "拍品 ID。"
          }
        }
      },
      "AutoMountLotResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "properties": {
              "lot": {
                "$ref": "#/components/schemas/AuctionLot"
              }
            }
          },
          "trace_id": {
            "type": "string"
          }
        }
      },
      "AuctionLot": {
        "type": "object",
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "uint64"
          },
          "itemId": {
            "type": "integer",
            "format": "uint64"
          },
          "sellerId": {
            "type": "string"
          },
          "liveRoomId": {
            "type": "integer",
            "format": "uint64"
          },
          "status": {
            "type": "string"
          },
          "startPrice": {
            "type": "integer",
            "format": "int64"
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64"
          },
          "capPrice": {
            "type": "integer",
            "format": "int64"
          },
          "incrementRule": {
            "type": "object"
          },
          "antiSnipingSec": {
            "type": "integer"
          },
          "antiExtendSec": {
            "type": "integer"
          },
          "antiExtendMode": {
            "type": "string"
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}

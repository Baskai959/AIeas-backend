{
  "openapi": "3.0.3",
  "info": {
    "title": "黑名单策略配置接口",
    "version": "1.0.0",
    "description": "后台管理自动黑名单策略配置。"
  },
  "paths": {
    "/api/v1/admin/risk/blacklist-strategy": {
      "get": {
        "summary": "查询黑名单策略配置",
        "tags": ["AdminRisk"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlacklistStrategyResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "更新黑名单策略配置",
        "tags": ["AdminRisk"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "description": "幂等键"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BlacklistStrategyPatch"
              },
              "examples": {
                "enableAll": {
                  "summary": "开启默认策略",
                  "value": { "enabled": true }
                },
                "customFrequency": {
                  "summary": "调整频控阈值",
                  "value": {
                    "enabled": true,
                    "frequencyEnabled": true,
                    "frequencyWindowMs": 1000,
                    "frequencyMaxRequests": 3,
                    "unreasonablePriceEnabled": true,
                    "missingDepositEnabled": true,
                    "blacklistDurationSeconds": 86400
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlacklistStrategyResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "BaseResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "example": 0 },
          "message": { "type": "string", "example": "success" },
          "trace_id": { "type": "string", "example": "trc_xxx" }
        },
        "required": ["code", "message"]
      },
      "BlacklistStrategyConfig": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "总开关。false 时只做原有拒绝，不自动写入黑名单。"
          },
          "frequencyEnabled": {
            "type": "boolean",
            "description": "开启出价频控触发自动拉黑。"
          },
          "frequencyWindowMs": {
            "type": "integer",
            "format": "int64",
            "minimum": 1,
            "maximum": 60000,
            "description": "频控窗口，默认 1000ms。"
          },
          "frequencyMaxRequests": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10000,
            "description": "窗口内允许请求数，超过后返回 FREQ_LIMIT 并自动拉黑。"
          },
          "unreasonablePriceEnabled": {
            "type": "boolean",
            "description": "开启异常高价自动拉黑。命中 ABOVE_MAX_BID_STEPS 或 ABOVE_CAP_PRICE 时生效。"
          },
          "missingDepositEnabled": {
            "type": "boolean",
            "description": "开启保证金/报名前置条件未满足自动拉黑。"
          },
          "blacklistDurationSeconds": {
            "type": "integer",
            "format": "int64",
            "minimum": 0,
            "description": "自动拉黑时长。0 表示永久黑名单。"
          }
        },
        "required": [
          "enabled",
          "frequencyEnabled",
          "frequencyWindowMs",
          "frequencyMaxRequests",
          "unreasonablePriceEnabled",
          "missingDepositEnabled"
        ]
      },
      "BlacklistStrategyPatch": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "frequencyEnabled": { "type": "boolean" },
          "frequencyWindowMs": { "type": "integer", "format": "int64" },
          "frequencyMaxRequests": { "type": "integer" },
          "unreasonablePriceEnabled": { "type": "boolean" },
          "missingDepositEnabled": { "type": "boolean" },
          "blacklistDurationSeconds": { "type": "integer", "format": "int64" }
        },
        "description": "字段均为可选；未传字段保留当前配置。"
      },
      "BlacklistStrategyResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/BaseResponse" },
          {
            "type": "object",
            "properties": {
              "data": { "$ref": "#/components/schemas/BlacklistStrategyConfig" }
            }
          }
        ]
      }
    }
  }
}

{
  "openapi": "3.0.3",
  "info": {
    "title": "拍品加价规则变更",
    "version": "v1",
    "description": "仅包含拍品创建、拍品更新接口中 incrementRule 的统一格式变更。固定加价使用 fixed，阶梯加价统一使用 ladder/steps/min/max，不再支持 tiered/tiers/from/to 别名。金额单位均为分。"
  },
  "servers": [
    {
      "url": "http://localhost:8888",
      "description": "Local"
    }
  ],
  "tags": [
    {
      "name": "Auction",
      "description": "拍品与拍卖管理"
    }
  ],
  "paths": {
    "/api/v1/auctions": {
      "post": {
        "tags": [
          "Auction"
        ],
        "summary": "创建拍品",
        "description": "需要 merchant 或 admin 角色。incrementRule 固定加价使用 fixed，阶梯加价统一使用 ladder。ladder.steps 按当前价匹配，min 含，max 不含，最后一档不传 max。",
        "operationId": "createAuction",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuctionCreateRequest"
              },
              "examples": {
                "fixed": {
                  "summary": "固定加价",
                  "value": {
                    "itemId": 1001,
                    "auctionType": "ENGLISH",
                    "startPrice": 1000,
                    "reservePrice": 50000,
                    "depositAmount": 20000,
                    "incrementRule": {
                      "type": "fixed",
                      "amount": 1000,
                      "maxBidSteps": 5
                    },
                    "antiSnipingSec": 15,
                    "antiExtendSec": 30,
                    "status": "READY",
                    "startTime": "2026-06-01T05:57:54.000Z",
                    "endTime": "2026-06-03T05:57:49.000Z"
                  }
                },
                "ladder": {
                  "summary": "阶梯加价",
                  "value": {
                    "itemId": 1001,
                    "auctionType": "ENGLISH",
                    "startPrice": 1000,
                    "reservePrice": 50000,
                    "depositAmount": 20000,
                    "incrementRule": {
                      "type": "ladder",
                      "maxBidSteps": 5,
                      "steps": [
                        {
                          "min": 0,
                          "max": 10000,
                          "amount": 1000
                        },
                        {
                          "min": 10000,
                          "amount": 5000
                        }
                      ]
                    },
                    "antiSnipingSec": 15,
                    "antiExtendSec": 30,
                    "status": "READY",
                    "startTime": "2026-06-01T05:57:54.000Z",
                    "endTime": "2026-06-03T05:57:49.000Z"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/AuctionLot"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ParamInvalid"
          },
          "401": {
            "$ref": "#/components/responses/AuthTokenInvalid"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/auctions/{id}": {
      "patch": {
        "tags": [
          "Auction"
        ],
        "summary": "更新拍品",
        "description": "需要 merchant 或 admin 角色。运行中、延时中、终态拍品不能修改 incrementRule 等拍卖规则字段。incrementRule 格式与创建拍品一致。",
        "operationId": "updateAuction",
        "parameters": [
          {
            "$ref": "#/components/parameters/AuctionIDPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuctionPatchRequest"
              },
              "example": {
                "incrementRule": {
                  "type": "ladder",
                  "maxBidSteps": 5,
                  "steps": [
                    {
                      "min": 0,
                      "max": 10000,
                      "amount": 1000
                    },
                    {
                      "min": 10000,
                      "amount": 5000
                    }
                  ]
                },
                "antiSnipingSec": 15,
                "antiExtendSec": 30
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/AuctionLot"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ParamInvalid"
          },
          "401": {
            "$ref": "#/components/responses/AuthTokenInvalid"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/AuctionNotFound"
          },
          "409": {
            "$ref": "#/components/responses/AuctionInvalidState"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "AuctionIDPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "uint64",
          "minimum": 1
        },
        "description": "拍品 ID"
      }
    },
    "schemas": {
      "AuctionCreateRequest": {
        "type": "object",
        "required": [
          "itemId"
        ],
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "description": "可选；不传由服务端生成"
          },
          "itemId": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1
          },
          "sellerId": {
            "type": "string",
            "description": "admin 可指定；merchant 请求中会强制使用当前登录商家"
          },
          "liveRoomId": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          },
          "auctionType": {
            "type": "string",
            "enum": [
              "ENGLISH"
            ],
            "default": "ENGLISH"
          },
          "startPrice": {
            "type": "integer",
            "format": "int64",
            "minimum": 0,
            "description": "起拍价，单位分"
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64",
            "minimum": 0,
            "description": "保留价，单位分"
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64",
            "minimum": 0,
            "description": "保证金金额，单位分"
          },
          "incrementRule": {
            "$ref": "#/components/schemas/IncrementRule"
          },
          "antiSnipingSec": {
            "type": "integer",
            "minimum": 1,
            "default": 15
          },
          "antiExtendSec": {
            "type": "integer",
            "minimum": 1,
            "default": 30
          },
          "status": {
            "$ref": "#/components/schemas/AuctionStatus"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time",
            "description": "必须晚于 startTime"
          }
        }
      },
      "AuctionPatchRequest": {
        "type": "object",
        "properties": {
          "startPrice": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "incrementRule": {
            "$ref": "#/components/schemas/IncrementRule"
          },
          "antiSnipingSec": {
            "type": "integer",
            "minimum": 1
          },
          "antiExtendSec": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "$ref": "#/components/schemas/AuctionStatus"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "IncrementRule": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FixedIncrementRule"
          },
          {
            "$ref": "#/components/schemas/LadderIncrementRule"
          }
        ],
        "description": "加价规则。固定加价使用 fixed，阶梯加价使用 ladder。金额单位均为分。"
      },
      "FixedIncrementRule": {
        "type": "object",
        "required": [
          "type",
          "amount",
          "maxBidSteps"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "fixed"
            ]
          },
          "amount": {
            "type": "integer",
            "format": "int64",
            "minimum": 1,
            "description": "固定最低加价金额，单位分"
          },
          "maxBidSteps": {
            "type": "integer",
            "minimum": 1,
            "description": "单次最高加价步数"
          }
        },
        "additionalProperties": false
      },
      "LadderIncrementRule": {
        "type": "object",
        "required": [
          "type",
          "maxBidSteps",
          "steps"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ladder"
            ]
          },
          "maxBidSteps": {
            "type": "integer",
            "minimum": 1,
            "description": "单次最高加价步数"
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50,
            "description": "阶梯必须从 min=0 开始连续覆盖；每一档 min 含、max 不含；最后一档必须不传 max。",
            "items": {
              "$ref": "#/components/schemas/LadderIncrementStep"
            }
          }
        },
        "additionalProperties": false
      },
      "LadderIncrementStep": {
        "type": "object",
        "required": [
          "min",
          "amount"
        ],
        "properties": {
          "min": {
            "type": "integer",
            "format": "int64",
            "minimum": 0,
            "description": "当前价下界，包含，单位分"
          },
          "max": {
            "type": "integer",
            "format": "int64",
            "minimum": 1,
            "description": "当前价上界，不包含，最后一档不传"
          },
          "amount": {
            "type": "integer",
            "format": "int64",
            "minimum": 1,
            "description": "该阶梯最低加价金额，单位分"
          }
        },
        "additionalProperties": false
      },
      "AuctionStatus": {
        "type": "string",
        "enum": [
          "DRAFT",
          "PENDING_AUDIT",
          "READY",
          "WARMING_UP",
          "RUNNING",
          "EXTENDED",
          "HAMMER_PENDING",
          "CLOSED_WON",
          "CLOSED_FAILED",
          "SETTLED"
        ]
      },
      "AuctionLot": {
        "type": "object",
        "properties": {
          "auctionId": {
            "type": "integer",
            "format": "uint64"
          },
          "itemId": {
            "type": "integer",
            "format": "uint64"
          },
          "sellerId": {
            "type": "string"
          },
          "liveRoomId": {
            "type": "integer",
            "format": "uint64"
          },
          "auctionType": {
            "type": "string",
            "enum": [
              "ENGLISH"
            ]
          },
          "startPrice": {
            "type": "integer",
            "format": "int64"
          },
          "reservePrice": {
            "type": "integer",
            "format": "int64"
          },
          "incrementRule": {
            "$ref": "#/components/schemas/IncrementRule"
          },
          "antiSnipingSec": {
            "type": "integer"
          },
          "antiExtendSec": {
            "type": "integer"
          },
          "depositAmount": {
            "type": "integer",
            "format": "int64"
          },
          "status": {
            "$ref": "#/components/schemas/AuctionStatus"
          },
          "ruleSnapshot": {
            "type": "object",
            "additionalProperties": true
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "winnerId": {
            "type": "string",
            "nullable": true
          },
          "dealPrice": {
            "type": "integer",
            "format": "int64",
            "nullable": true
          },
          "closedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "closedBy": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "nullable": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "nullable": true
          }
        }
      }
    },
    "responses": {
      "ParamInvalid": {
        "description": "参数不合法，例如 incrementRule 格式不符合 fixed 或 ladder 统一格式",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "code": 20001,
              "message": "参数不合法",
              "data": null
            }
          }
        }
      },
      "AuthTokenInvalid": {
        "description": "登录态无效或缺失"
      },
      "Forbidden": {
        "description": "无权限操作该商品或拍品"
      },
      "AuctionNotFound": {
        "description": "拍品不存在"
      },
      "AuctionInvalidState": {
        "description": "拍品状态不允许修改规则字段"
      },
      "InternalError": {
        "description": "系统内部错误"
      }
    }
  }
}

{
  "openapi": "3.0.3",
  "info": {
    "title": "直播总结报告接口",
    "version": "v1",
    "description": "商家闭播后，后端自动为该直播场次创建 AI 总结任务并调用 Agent 异步接口 POST /api/v1/live-analysis/async。前端按直播场次 ID 调用 GET /api/v1/live-analysis/reports/{liveSessionId} 查询报告：生成中返回 RUNNING，成功后返回 report 内容；失败任务在未达到 3 次尝试前会在查询时自动重试，达到 3 次后返回 FAILED。"
  },
  "servers": [
    {
      "url": "http://localhost:8888",
      "description": "Local"
    }
  ],
  "tags": [
    {
      "name": "LiveAnalysis",
      "description": "直播 AI 总结报告"
    }
  ],
  "paths": {
    "/api/v1/live-analysis/reports/{liveSessionId}": {
      "get": {
        "tags": [
          "LiveAnalysis"
        ],
        "summary": "按直播场次查询总结报告",
        "description": "需要 merchant 或 admin 角色。merchant 只能查询自己的直播场次；admin 可查询任意场次。若该场次已闭播但数据库中尚无报告任务，后端会创建任务并调用 Agent，返回 RUNNING。若任务失败且 attemptCount < 3，后端会再次调用 Agent 重试；重试受理后返回 RUNNING。若 attemptCount 已达到 3 且仍失败，返回 FAILED。若 Agent 已回调成功，返回 SUCCEEDED 且 data.report 为报告内容。",
        "operationId": "getLiveAnalysisReportBySession",
        "parameters": [
          {
            "name": "liveSessionId",
            "in": "path",
            "required": true,
            "description": "直播场次 ID，即 live_session.id。",
            "schema": {
              "type": "integer",
              "format": "uint64",
              "example": 70001
            }
          }
        ],
        "responses": {
          "200": {
            "description": "查询成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/LiveAnalysisReportTask"
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "running": {
                    "summary": "生成中",
                    "value": {
                      "code": 0,
                      "message": "success",
                      "data": {
                        "taskId": "lar_2fce5f7c0c9a4e1d9a1d8fd7bb0fd625",
                        "agentRequestId": "c8d8a4c0e9c84b219688c6e29f4d91af",
                        "liveSessionId": 70001,
                        "merchantId": "u_2001",
                        "status": "RUNNING",
                        "attemptCount": 1,
                        "prompt": "帮我总结商家id为u_2001直播场次id为70001的直播情况，重点看成交、出价、订单和风险问题。",
                        "report": "",
                        "createdAt": "2026-05-26T10:00:00Z",
                        "updatedAt": "2026-05-26T10:00:01Z"
                      },
                      "trace_id": "req_1710000000000000000"
                    }
                  },
                  "succeeded": {
                    "summary": "生成成功",
                    "value": {
                      "code": 0,
                      "message": "success",
                      "data": {
                        "taskId": "lar_2fce5f7c0c9a4e1d9a1d8fd7bb0fd625",
                        "agentRequestId": "c8d8a4c0e9c84b219688c6e29f4d91af",
                        "liveSessionId": 70001,
                        "merchantId": "u_2001",
                        "status": "SUCCEEDED",
                        "attemptCount": 1,
                        "prompt": "帮我总结商家id为u_2001直播场次id为70001的直播情况，重点看成交、出价、订单和风险问题。",
                        "report": "大模型输出内容",
                        "createdAt": "2026-05-26T10:00:00Z",
                        "updatedAt": "2026-05-26T10:00:08Z"
                      },
                      "trace_id": "req_1710000000000000000"
                    }
                  },
                  "failed": {
                    "summary": "三次失败后不再重试",
                    "value": {
                      "code": 0,
                      "message": "success",
                      "data": {
                        "taskId": "lar_2fce5f7c0c9a4e1d9a1d8fd7bb0fd625",
                        "liveSessionId": 70001,
                        "merchantId": "u_2001",
                        "status": "FAILED",
                        "attemptCount": 3,
                        "prompt": "帮我总结商家id为u_2001直播场次id为70001的直播情况，重点看成交、出价、订单和风险问题。",
                        "report": "",
                        "errorMessage": "模型服务超时",
                        "createdAt": "2026-05-26T10:00:00Z",
                        "updatedAt": "2026-05-26T10:02:00Z"
                      },
                      "trace_id": "req_1710000000000000000"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ParamInvalid"
          },
          "401": {
            "$ref": "#/components/responses/AuthTokenInvalid"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/InvalidState"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v1/live-analysis/callback": {
      "post": {
        "tags": [
          "LiveAnalysis"
        ],
        "summary": "Agent 直播总结完成回调",
        "description": "供 Agent 服务调用。后端调用 Agent 时会把该地址作为 callback_url 传入，并在 callback_headers 中携带 X-Callback-Key 和 Authorization: Bearer <callbackKey>。回调成功后，后端根据 callback_context.taskId 或 liveSessionId 更新数据库中的报告记录。",
        "operationId": "liveAnalysisCallback",
        "parameters": [
          {
            "name": "X-Callback-Key",
            "in": "header",
            "required": false,
            "description": "回调鉴权密钥。也可以使用 Authorization: Bearer <callbackKey>。",
            "schema": {
              "type": "string",
              "example": "callback-token"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LiveAnalysisCallbackRequest"
              },
              "example": {
                "request_id": "c8d8a4c0e9c84b219688c6e29f4d91af",
                "success": true,
                "status": "COMPLETED",
                "summary": "直播总结与运营建议",
                "error_message": null,
                "callback_context": {
                  "taskId": "lar_2fce5f7c0c9a4e1d9a1d8fd7bb0fd625",
                  "liveSessionId": 70001,
                  "merchantId": "u_2001",
                  "attempt": 1
                },
                "completed_at": "2026-05-26T10:30:00Z"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "回调处理成功，报告记录已更新",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/LiveAnalysisReportTask"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ParamInvalid"
          },
          "401": {
            "$ref": "#/components/responses/AuthTokenInvalid"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "callbackKey": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "callbackKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Callback-Key"
      }
    },
    "schemas": {
      "LiveAnalysisReportTask": {
        "type": "object",
        "required": [
          "taskId",
          "liveSessionId",
          "merchantId",
          "status",
          "attemptCount",
          "prompt",
          "report",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "taskId": {
            "type": "string",
            "description": "后端报告任务 ID。",
            "example": "lar_2fce5f7c0c9a4e1d9a1d8fd7bb0fd625"
          },
          "agentRequestId": {
            "type": "string",
            "description": "Agent 异步任务 ID。任务尚未成功受理或受理失败时可能为空。",
            "example": "c8d8a4c0e9c84b219688c6e29f4d91af"
          },
          "liveSessionId": {
            "type": "integer",
            "format": "uint64",
            "example": 70001
          },
          "merchantId": {
            "type": "string",
            "example": "u_2001"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "RUNNING",
              "SUCCEEDED",
              "FAILED"
            ],
            "description": "RUNNING 表示生成中；SUCCEEDED 表示 report 已可展示；FAILED 表示已失败，attemptCount=3 时前端可展示最终失败。",
            "example": "SUCCEEDED"
          },
          "attemptCount": {
            "type": "integer",
            "description": "后端已调用 Agent 的次数，最大为 3。",
            "example": 1
          },
          "prompt": {
            "type": "string",
            "example": "帮我总结商家id为u_2001直播场次id为70001的直播情况，重点看成交、出价、订单和风险问题。"
          },
          "report": {
            "type": "string",
            "description": "AI 生成的直播总结。接口始终返回该字段；空字符串表示报告尚未成功生成，非空字符串表示已生成。来源为 Agent 回调的 summary 字段。",
            "example": "大模型输出内容"
          },
          "errorMessage": {
            "type": "string",
            "description": "失败原因。仅 status=FAILED 时返回。",
            "example": "模型服务超时"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-26T10:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-26T10:00:08Z"
          }
        }
      },
      "LiveAnalysisCallbackRequest": {
        "type": "object",
        "required": [
          "request_id",
          "success",
          "status",
          "summary",
          "callback_context",
          "completed_at"
        ],
        "properties": {
          "request_id": {
            "type": "string",
            "description": "Agent 异步任务 ID。",
            "example": "c8d8a4c0e9c84b219688c6e29f4d91af"
          },
          "success": {
            "type": "boolean",
            "example": true
          },
          "status": {
            "type": "string",
            "enum": [
              "COMPLETED",
              "FAILED"
            ],
            "example": "COMPLETED"
          },
          "summary": {
            "type": "string",
            "description": "成功时为直播总结；失败时可为失败摘要。后端只在 success=true 且 status=COMPLETED 时写入 report。",
            "example": "直播总结与运营建议"
          },
          "error_message": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "callback_context": {
            "type": "object",
            "description": "Agent 原样返回的上下文。后端优先使用 taskId 定位任务，也支持 liveSessionId 兜底；attempt 用于忽略过期回调。",
            "additionalProperties": true,
            "example": {
              "taskId": "lar_2fce5f7c0c9a4e1d9a1d8fd7bb0fd625",
              "liveSessionId": 70001,
              "merchantId": "u_2001",
              "attempt": 1
            }
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-26T10:30:00Z"
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "nullable": true
          },
          "trace_id": {
            "type": "string",
            "example": "req_1710000000000000000"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 20001
          },
          "message": {
            "type": "string",
            "example": "参数不合法"
          },
          "data": {
            "nullable": true,
            "example": null
          },
          "trace_id": {
            "type": "string",
            "example": "req_1710000000000000000"
          }
        }
      }
    },
    "responses": {
      "ParamInvalid": {
        "description": "参数不合法，例如 liveSessionId 不是正整数。",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "AuthTokenInvalid": {
        "description": "访问令牌无效、缺失或已过期。",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "无访问权限。buyer 不能访问；merchant 不能查询其他商家的直播场次。",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "直播场次不存在，或回调对应的报告任务不存在。",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "InvalidState": {
        "description": "直播场次尚未闭播，不能生成总结报告。",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "InternalError": {
        "description": "系统内部错误。",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}

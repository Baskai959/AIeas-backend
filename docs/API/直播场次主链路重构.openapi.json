{
  "openapi": "3.0.3",
  "info": {
    "title": "直播场次主链路重构接口",
    "version": "1.0.0",
    "description": "merchant -> live_session 主链路接口，live_session 承载直播展示信息和开播到下播生命周期。"
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "paths": {
    "/live-sessions": {
      "post": {
        "summary": "创建直播场次",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LiveSessionCreate" }
            }
          }
        },
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSession" } } } } }
      },
      "get": {
        "summary": "查询当前商家的直播场次列表",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "$ref": "#/components/schemas/LiveSessionStatus" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "object", "properties": { "sessions": { "type": "array", "items": { "$ref": "#/components/schemas/LiveSession" } } } } } } } }
      }
    },
    "/live-sessions/{id}": {
      "get": { "summary": "获取直播场次详情", "parameters": [{ "$ref": "#/components/parameters/SessionId" }], "responses": { "200": { "description": "OK" } } },
      "patch": { "summary": "编辑直播场次", "parameters": [{ "$ref": "#/components/parameters/SessionId" }], "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LiveSessionPatch" } } } }, "responses": { "200": { "description": "OK" } } }
    },
    "/live-sessions/{id}/start": { "post": { "summary": "开播", "parameters": [{ "$ref": "#/components/parameters/SessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "responses": { "200": { "description": "OK" } } } },
    "/live-sessions/{id}/end": { "post": { "summary": "下播", "parameters": [{ "$ref": "#/components/parameters/SessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "responses": { "200": { "description": "OK" } } } },
    "/live-sessions/{id}/lots": {
      "post": { "summary": "挂载拍品（body 只传 auctionId）", "parameters": [{ "$ref": "#/components/parameters/SessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuctionIdBody" } } } }, "responses": { "200": { "description": "OK" } } },
      "get": { "summary": "查询本场拍品", "parameters": [{ "$ref": "#/components/parameters/SessionId" }], "responses": { "200": { "description": "OK" } } }
    },
    "/live-sessions/{id}/lots/{auctionId}": { "delete": { "summary": "移除本场拍品", "parameters": [{ "$ref": "#/components/parameters/SessionId" }, { "name": "auctionId", "in": "path", "required": true, "schema": { "type": "integer", "format": "uint64" } }, { "$ref": "#/components/parameters/IdempotencyKey" }], "responses": { "200": { "description": "OK" } } } },
    "/live-sessions/{id}/activate": { "post": { "summary": "讲解/开拍本场拍品", "parameters": [{ "$ref": "#/components/parameters/SessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ActivateBody" } } } }, "responses": { "200": { "description": "OK" } } } },
    "/live-sessions/{id}/deactivate": { "post": { "summary": "取消讲解", "parameters": [{ "$ref": "#/components/parameters/SessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "responses": { "200": { "description": "OK" } } } },
    "/live-sessions/{id}/bids": { "get": { "summary": "查询本场出价", "parameters": [{ "$ref": "#/components/parameters/SessionId" }], "responses": { "200": { "description": "OK" } } } },
    "/live-sessions/{id}/orders": { "get": { "summary": "查询本场订单", "parameters": [{ "$ref": "#/components/parameters/SessionId" }], "responses": { "200": { "description": "OK" } } } },
    "/live-sessions/{id}/stats": { "get": { "summary": "查询本场统计", "parameters": [{ "$ref": "#/components/parameters/SessionId" }], "responses": { "200": { "description": "OK" } } } },
    "/live-sessions/{id}/cover": { "post": { "summary": "上传场次封面", "parameters": [{ "$ref": "#/components/parameters/SessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "requestBody": { "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "image": { "type": "string", "format": "binary" } } } } } }, "responses": { "200": { "description": "OK" } } } },
    "/live-sessions/{id}/agent-hook": { "get": { "summary": "查询 AI Agent Hook 开关", "parameters": [{ "$ref": "#/components/parameters/SessionId" }], "responses": { "200": { "description": "OK" } } }, "patch": { "summary": "设置 AI Agent Hook 开关", "parameters": [{ "$ref": "#/components/parameters/SessionId" }, { "$ref": "#/components/parameters/IdempotencyKey" }], "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "enabled": { "type": "boolean" } }, "required": ["enabled"] } } } }, "responses": { "200": { "description": "OK" } } } }
  },
  "components": {
    "parameters": {
      "SessionId": { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "uint64" } },
      "IdempotencyKey": { "name": "Idempotency-Key", "in": "header", "required": true, "schema": { "type": "string" } }
    },
    "schemas": {
      "LiveSessionStatus": { "type": "string", "enum": ["DRAFT", "SCHEDULED", "LIVE", "ENDED", "CANCELLED"] },
      "LiveSessionCreate": { "type": "object", "required": ["title"], "properties": { "merchantId": { "type": "string" }, "title": { "type": "string" }, "description": { "type": "string" }, "coverUrl": { "type": "string" }, "status": { "$ref": "#/components/schemas/LiveSessionStatus" }, "scheduledStartTime": { "type": "string", "format": "date-time" }, "plannedDurationSec": { "type": "integer" } } },
      "LiveSessionPatch": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" }, "coverUrl": { "type": "string" }, "status": { "$ref": "#/components/schemas/LiveSessionStatus" }, "scheduledStartTime": { "type": "string", "format": "date-time" }, "plannedDurationSec": { "type": "integer" } } },
      "LiveSession": { "allOf": [{ "$ref": "#/components/schemas/LiveSessionCreate" }, { "type": "object", "properties": { "id": { "type": "integer", "format": "uint64" }, "merchantId": { "type": "string" }, "activeAuctionId": { "type": "integer", "format": "uint64" }, "openedAt": { "type": "string", "format": "date-time" }, "closedAt": { "type": "string", "format": "date-time" }, "lotsTotal": { "type": "integer" }, "lotsSold": { "type": "integer" }, "lotsUnsold": { "type": "integer" }, "bidCount": { "type": "integer" }, "gmvCent": { "type": "integer", "format": "int64" }, "viewerPeak": { "type": "integer" }, "viewerTotal": { "type": "integer" }, "createdAt": { "type": "string", "format": "date-time" }, "updatedAt": { "type": "string", "format": "date-time" } } }] },
      "AuctionIdBody": { "type": "object", "required": ["auctionId"], "properties": { "auctionId": { "type": "integer", "format": "uint64" } } },
      "ActivateBody": { "type": "object", "required": ["auctionId"], "properties": { "auctionId": { "type": "integer", "format": "uint64" }, "durationSec": { "type": "integer" } } }
    }
  }
}

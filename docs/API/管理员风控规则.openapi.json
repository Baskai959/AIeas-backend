{
  "openapi": "3.0.3",
  "info": {
    "title": "管理员风控规则接口",
    "version": "1.0.0",
    "description": "管理端风控规则读取与保存接口契约。用于补齐联调中确认的 /api/v1/admin/risk/rules 读写契约。"
  },
  "servers": [
    {
      "url": "http://localhost:8888",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "Admin Risk Rules",
      "description": "管理员风控规则配置"
    }
  ],
  "paths": {
    "/api/v1/admin/risk/rules": {
      "get": {
        "summary": "读取风控规则",
        "description": "读取管理端当前风控规则配置。仅 admin 角色可访问。",
        "operationId": "adminGetRiskRules",
        "tags": [
          "Admin Risk Rules"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "读取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RiskRulesResponse"
                },
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "bidMaxQps": 10,
                    "blacklistEnabled": true,
                    "selfOverbidBlocked": true,
                    "suspiciousIpThreshold": 3
                  },
                  "trace_id": "req_risk_rules_get"
                }
              }
            }
          },
          "401": {
            "description": "缺少或无效访问令牌",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "非管理员角色访问",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "保存风控规则",
        "description": "保存管理端风控规则配置，并返回保存后的规则对象。仅 admin 角色可访问。",
        "operationId": "adminUpdateRiskRules",
        "tags": [
          "Admin Risk Rules"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RiskRulesPayload"
              },
              "example": {
                "bidMaxQps": 10,
                "blacklistEnabled": true,
                "selfOverbidBlocked": true,
                "suspiciousIpThreshold": 3
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "保存成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RiskRulesResponse"
                },
                "example": {
                  "code": 0,
                  "message": "success",
                  "data": {
                    "bidMaxQps": 10,
                    "blacklistEnabled": true,
                    "selfOverbidBlocked": true,
                    "suspiciousIpThreshold": 3
                  },
                  "trace_id": "req_risk_rules_put"
                }
              }
            }
          },
          "400": {
            "description": "参数不合法或缺少 Idempotency-Key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "缺少或无效访问令牌",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "非管理员角色访问",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "幂等请求冲突",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "写接口幂等键。"
      }
    },
    "schemas": {
      "RiskRulesPayload": {
        "type": "object",
        "required": [
          "bidMaxQps",
          "blacklistEnabled",
          "selfOverbidBlocked",
          "suspiciousIpThreshold"
        ],
        "properties": {
          "bidMaxQps": {
            "type": "integer",
            "minimum": 0,
            "description": "单用户或单 IP 出价频率上限，单位 QPS。"
          },
          "blacklistEnabled": {
            "type": "boolean",
            "description": "是否启用黑名单拦截。"
          },
          "selfOverbidBlocked": {
            "type": "boolean",
            "description": "是否禁止当前领先者继续自我加价。"
          },
          "suspiciousIpThreshold": {
            "type": "integer",
            "minimum": 0,
            "description": "可疑 IP 判定阈值。"
          }
        }
      },
      "RiskRulesResponse": {
        "type": "object",
        "required": [
          "code",
          "message",
          "data",
          "trace_id"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "example": 0
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/RiskRulesPayload"
          },
          "trace_id": {
            "type": "string",
            "example": "req_risk_rules_get"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 20001
          },
          "message": {
            "type": "string",
            "example": "参数不合法"
          },
          "data": {
            "nullable": true
          },
          "trace_id": {
            "type": "string",
            "example": "req_risk_rules_error"
          }
        }
      }
    }
  }
}

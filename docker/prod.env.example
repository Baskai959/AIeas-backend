# Copy to docker/prod.env on the server and replace every change-me value.
# Do not commit docker/prod.env.
#
# 约定：docker/prod.env 只承载 Docker 容器凭证与应用密钥。
# 应用端口、角色、MySQL/Redis 地址、连接池、Kafka topic、开关、超时、
# WebSocket 限流、观测配置等普通应用配置统一写在 configs/config.docker.yaml。

# MySQL 容器初始化凭证；configs/config.docker.yaml 里的 mysql.dsn 密码需与 MYSQL_PASSWORD 保持一致。
MYSQL_DATABASE=aieas
MYSQL_USER=auction
MYSQL_PASSWORD=change-me-mysql-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# Redis 容器密码；地址、DB、连接池大小只在 configs/config.docker.yaml 配置。
REDIS_RT_SHARD_0_PASSWORD=
REDIS_RT_SHARD_1_PASSWORD=
REDIS_CACHE_PASSWORD=

# JWT 签名密钥；生产必须替换为高强度随机值。
JWT_SECRET=change-me-to-a-long-random-jwt-secret

# 火山 TOS / 对象存储访问凭证；enabled、endpoint、bucket 等只在 configs/config.docker.yaml 配置。
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# 直播分析回调鉴权 key；Agent URL、开关、超时只在 configs/config.docker.yaml 配置。
AGENT_LIVE_ANALYSIS_CALLBACK_API_KEY=change-me-live-analysis-callback-key

# 豆包 TTS 凭证；voice 只在 configs/config.docker.yaml 配置。
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACK_TOKEN=

# MCP API key；actorID / actorRole 只在 configs/config.docker.yaml 配置。
MCP_READ_API_KEY=change-me-read-mcp-api-key
MCP_CONTROL_API_KEY=change-me-control-mcp-api-key

# /metrics 访问令牌；metrics path、namespace、enabled 等只在 configs/config.docker.yaml 配置。
OBSERVABILITY_METRICS_AUTH_TOKEN=change-me-metrics-token
